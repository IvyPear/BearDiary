<% title = 'Chỉnh sửa nhật ký - Bear Diary' %>

<div class="max-w-2xl mx-auto p-6">
	<h2 class="text-2xl font-bold mb-4">Chỉnh sửa nhật ký</h2>

	<form action="/diaries/update/<%= entry._id %>" method="POST">
		<div class="mb-4">
			<label class="block text-sm font-semibold mb-1">Mood</label>
			<input name="mood" type="text" value="<%= entry.mood %>" class="w-full border rounded px-3 py-2" />
		</div>

		<div class="mb-4">
			<label class="block text-sm font-semibold mb-1">Nội dung</label>
			<textarea name="content" rows="6" class="w-full border rounded px-3 py-2"><%= entry.content %></textarea>
		</div>

		<div class="flex gap-3">
			<button type="submit" class="px-4 py-2 bg-[#5A9BD4] text-white rounded font-bold">Lưu</button>
			<a href="/diaries/timeline" class="px-4 py-2 border rounded">Hủy</a>
		</div>
	</form>
</div>
