<% title = 'Chỉnh sửa hồ sơ - Bear Diary'; %>

<link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<style>
  .edit-profile-card { max-width: 820px; margin: 0 auto; padding: 2rem; border-radius: 1rem; background: var(--card-bg, white); border: 1px solid var(--card-border); }
  .avatar-preview { width: 120px; height: 120px; border-radius: 999px; overflow: hidden; display: inline-block; border: 2px solid var(--card-border); background: var(--card-bg); position: relative; }
  .avatar-preview img { width: 100%; height: 100%; object-fit: cover; }
  .avatar-fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 48px; font-weight: bold; background: linear-gradient(135deg, var(--accent) 0%, var(--accent-light) 100%); color: white; }
  
  /* Dark mode styles */
  /* Use theme variables so dark/light share the same rules */
  .edit-profile-card { background: var(--card-bg); border-color: var(--card-border); }
  .form-label { color: var(--muted); }
  .avatar-preview { border-color: var(--card-border); background: var(--card-bg); }
  
  /* Dark mode cho input và textarea */
  input,
  textarea {
    background-color: var(--card-bg);
    border-color: var(--card-border);
    color: var(--primary-dark);
  }
  
  [data-theme="dark"] input:focus,
  [data-theme="dark"] textarea:focus {
    border-color: var(--accent, #60A5FA);
    outline: none;
    box-shadow: 0 0 0 2px rgba(96, 165, 250, 0.2);
  }
  
  input::placeholder,
  textarea::placeholder {
    color: var(--muted);
  }
  
  .border {
    border-color: var(--card-border);
  }
  
  .hover\:bg-gray-50:hover {
    background-color: var(--card-border) !important;
  }
  
  a { color: var(--muted); }
  a:hover { color: var(--primary-dark); }
  
  .small-muted { font-size: .85rem; color: var(--muted,#6B7280); }
  
  .crop-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    z-index: 1000;
    justify-content: center;
    align-items: center;
  }
  .crop-modal.active { display: flex; }
  .crop-container {
    background: white;
    border-radius: 1rem;
    padding: 1.5rem;
    max-width: 90vw;
    max-height: 90vh;
    overflow: auto;
  }
  .crop-container { background: var(--card-bg); }
  .crop-image-container {
    max-width: 70vw;
    max-height: 60vh;
    margin: 1rem 0;
    overflow: hidden;
  }
  .crop-image-container img { max-width: 100%; display: block; }
  .crop-buttons { display: flex; gap: 1rem; justify-content: center; margin-top: 1rem; }
  .crop-buttons button { padding: 0.5rem 1.5rem; border-radius: 0.5rem; font-weight: bold; cursor: pointer; border: none; }
  .btn-crop { background: var(--accent); color: white; }
  .btn-cancel { background: var(--card-border); color: var(--primary-dark); }
  .loading {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(0,0,0,0.9);
    color: white;
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    z-index: 1001;
    display: none;
    font-size: 14px;
  }
  .toast-message {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #333;
    color: white;
    padding: 12px 20px;
    border-radius: 8px;
    z-index: 1002;
    display: none;
    animation: slideIn 0.3s ease;
  }
  .toast-message.success { background: #10b981; }
  .toast-message.error { background: #ef4444; }
  @keyframes slideIn {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }
</style>

<div class="edit-profile-card">
  <h2 class="text-2xl font-bold mb-4">Chỉnh sửa hồ sơ</h2>

  <form id="editProfileForm">
    <div class="flex gap-8 items-start flex-wrap">
      <div class="text-center">
        <label class="form-label block mb-2">Ảnh đại diện</label>
        <div class="avatar-preview mb-3" id="currentAvatar">
          <% if (user.avatar && user.avatar !== 'U' && !user.avatar.match(/^[A-Z]$/)) { %>
            <img id="avatarImg" src="<%= user.avatar %>" alt="avatar">
          <% } else { %>
            <div id="avatarFallback" class="avatar-fallback"><%= (user.name || 'U').charAt(0).toUpperCase() %></div>
          <% } %>
        </div>

        <input type="file" id="avatarFile" accept="image/jpeg,image/png,image/jpg,image/gif" class="mb-2" />
        <div class="small-muted">Bạn có thể chọn ảnh từ máy tính. Kích thước tối đa 2MB.</div>
        <div id="fileError" class="error-message" style="color: #ef4444; font-size: 12px; margin-top: 5px;"></div>
      </div>

      <div class="flex-1">
        <label class="form-label block mb-2">Tên</label>
        <input name="name" id="userName" type="text" value="<%= user.name %>" required class="w-full border rounded px-3 py-2 mb-4" />

        <label class="form-label block mb-2">Email</label>
        <input name="email" id="userEmail" type="email" value="<%= user.email %>" required class="w-full border rounded px-3 py-2" />
      </div>
    </div>

    <div class="flex gap-3 mt-6">
      <button type="button" id="saveBtn" class="px-4 py-2 accent-bg btn-accent text-white rounded font-bold transition-colors">Lưu</button>
      <a href="/diaries/profile" class="px-4 py-2 border rounded hover:bg-gray-50 transition-colors">Hủy</a>
    </div>
  </form>
</div>

<div id="loading" class="loading">
  <i class="fa-solid fa-spinner fa-spin"></i> Đang xử lý...
</div>

<div id="toast" class="toast-message"></div>

<div id="cropModal" class="crop-modal">
  <div class="crop-container">
    <h3 class="text-xl font-bold mb-4 text-center">Cắt ảnh đại diện</h3>
    <p class="text-sm text-gray-500 text-center mb-2">👆 Kéo thả để chọn vùng ảnh</p>
    <div class="crop-image-container">
      <img id="cropImage" src="" alt="Image to crop">
    </div>
    <div class="crop-buttons">
      <button id="cropCancelBtn" class="btn-cancel">Hủy</button>
      <button id="cropSaveBtn" class="btn-crop">Cắt & Lưu</button>
    </div>
  </div>
</div>

<script>
  let cropper = null;
  let pendingFile = null;
  let isUploading = false;

  // Hiển thị toast message
  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = message;
    toast.className = `toast-message ${type}`;
    toast.style.display = 'block';
    setTimeout(() => {
      toast.style.display = 'none';
    }, 3000);
  }

  // Cập nhật avatar preview
  function updateAvatarPreview(imageUrl) {
    const avatarPreview = document.getElementById('currentAvatar');
    const existingImg = document.getElementById('avatarImg');
    
    if (existingImg) {
      existingImg.src = imageUrl;
      existingImg.style.display = 'block';
      const fallback = document.getElementById('avatarFallback');
      if (fallback) fallback.style.display = 'none';
    } else {
      avatarPreview.innerHTML = `<img id="avatarImg" src="${imageUrl}" alt="avatar" style="width:100%;height:100%;object-fit:cover">`;
    }
  }

  // Resize ảnh trước khi crop
  function resizeImage(file, maxSize, callback) {
    const reader = new FileReader();
    reader.onload = function(e) {
      const img = new Image();
      img.onload = function() {
        let width = img.width;
        let height = img.height;
        
        if (width > maxSize || height > maxSize) {
          const ratio = Math.min(maxSize / width, maxSize / height);
          width = width * ratio;
          height = height * ratio;
          
          const canvas = document.createElement('canvas');
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, width, height);
          
          canvas.toBlob(blob => callback(blob), file.type, 0.9);
        } else {
          callback(file);
        }
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  }

  // Xử lý chọn file
  document.getElementById('avatarFile').addEventListener('change', function(e) {
    const file = e.target.files[0];
    const fileError = document.getElementById('fileError');
    fileError.innerHTML = '';
    
    if (!file) return;
    
    if (file.size > 5 * 1024 * 1024) {
      fileError.innerHTML = '❌ File quá lớn! Chọn ảnh nhỏ hơn 5MB';
      this.value = '';
      return;
    }
    
    const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
    if (!allowedTypes.includes(file.type)) {
      fileError.innerHTML = '❌ Chỉ chấp nhận JPG, PNG, GIF';
      this.value = '';
      return;
    }
    
    const loading = document.getElementById('loading');
    loading.style.display = 'block';
    
    resizeImage(file, 1200, (resizedBlob) => {
      pendingFile = resizedBlob;
      const reader = new FileReader();
      reader.onload = function(e) {
        loading.style.display = 'none';
        
        const cropImage = document.getElementById('cropImage');
        cropImage.src = e.target.result;
        document.getElementById('cropModal').classList.add('active');
        
        const initCropper = () => {
          if (cropper) cropper.destroy();
          cropper = new Cropper(cropImage, {
            aspectRatio: 1,
            viewMode: 2,
            dragMode: 'move',
            autoCropArea: 1,
            zoomable: true,
            minCropBoxWidth: 100,
            minCropBoxHeight: 100
          });
        };
        
        if (cropImage.complete) initCropper();
        else cropImage.onload = initCropper;
      };
      reader.readAsDataURL(resizedBlob);
    });
  });

  // Đóng modal
  window.closeCropModal = function() {
    document.getElementById('cropModal').classList.remove('active');
    if (cropper) {
      cropper.destroy();
      cropper = null;
    }
    document.getElementById('avatarFile').value = '';
    pendingFile = null;
  };

  // Cắt và upload
  window.cropAndUpload = async function() {
    if (!cropper || isUploading) return;
    
    isUploading = true;
    const loading = document.getElementById('loading');
    loading.style.display = 'block';
    
    try {
      const canvas = cropper.getCroppedCanvas({ width: 400, height: 400 });
      if (!canvas) throw new Error('Không thể cắt ảnh');
      
      const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.85));
      if (!blob) throw new Error('Không thể xử lý ảnh');
      
      const formData = new FormData();
      formData.append('avatarFile', blob, 'avatar.jpg');
      formData.append('name', document.getElementById('userName').value);
      formData.append('email', document.getElementById('userEmail').value);
      
      const response = await fetch('/diaries/profile/update', {
        method: 'POST',
        body: formData,
        credentials: 'same-origin',
        headers: { 'Accept': 'application/json' }
      });
      
      const result = await response.json();
      
      if (result.ok) {
        // Cập nhật avatar ngay lập tức
        const avatarUrl = result.avatar + '?t=' + Date.now(); // Cache bust
        updateAvatarPreview(avatarUrl);
        
        // Cập nhật session trong localStorage để đồng bộ trang profile
        localStorage.setItem('avatarUpdated', Date.now());
        
        showToast('✅ Cập nhật avatar thành công!', 'success');
        closeCropModal();
        
        // Reload trang profile sau 1 giây
        setTimeout(() => {
          window.location.href = '/diaries/profile';
        }, 1000);
      } else {
        throw new Error(result.error || 'Cập nhật thất bại');
      }
    } catch (error) {
      console.error(error);
      showToast('❌ ' + error.message, 'error');
    } finally {
      loading.style.display = 'none';
      isUploading = false;
    }
  };

  // Lưu thông tin (không đổi avatar)
  document.getElementById('saveBtn').addEventListener('click', async function() {
    if (isUploading) return;
    
    const loading = document.getElementById('loading');
    loading.style.display = 'block';
    
    const formData = new FormData();
    formData.append('name', document.getElementById('userName').value);
    formData.append('email', document.getElementById('userEmail').value);
    
    try {
      const response = await fetch('/diaries/profile/update', {
        method: 'POST',
        body: formData,
        credentials: 'same-origin',
        headers: { 'Accept': 'application/json' }
      });
      
      const result = await response.json();
      
      if (result.ok) {
        showToast('✅ Cập nhật thông tin thành công!', 'success');
        setTimeout(() => {
          window.location.href = '/diaries/profile';
        }, 800);
      } else {
        throw new Error(result.error || 'Cập nhật thất bại');
      }
    } catch (error) {
      console.error(error);
      showToast('❌ ' + error.message, 'error');
    } finally {
      loading.style.display = 'none';
    }
  });

  // Gắn event cho các nút trong modal (tránh inline handlers)
  document.addEventListener('DOMContentLoaded', function () {
    const cancel = document.getElementById('cropCancelBtn');
    if (cancel) cancel.addEventListener('click', window.closeCropModal);
    const save = document.getElementById('cropSaveBtn');
    if (save) save.addEventListener('click', window.cropAndUpload);
  });
</script>