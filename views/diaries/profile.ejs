<% title = 'Cá nhân - Bear Diary'; %>

<div class="flex items-center gap-4 mb-8">
    <div class="w-12 h-12 flex items-center justify-center text-white text-xl shadow-lg rounded-2xl" style="background: var(--accent)">
      <i class="fa-solid fa-user-gear"></i>
    </div>
    <div>
      <h2 class="text-3xl font-black">Hồ sơ của tôi</h2>
      <p class="text-slate-400 font-bold text-sm">Cập nhật thông tin và phong cách của bạn</p>
    </div>
</div>

<div class="profile-card-main mb-8">
    <div class="banner-box"></div>
    <div class="avatar-container">
      <% if (user.avatar && user.avatar !== 'U' && !user.avatar.match(/^[A-Z]$/)) { %>
        <img src="<%= user.avatar %>" alt="<%= user.name %>">
      <% } else { %>
        <div class="avatar-fallback"><%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %></div>
      <% } %>
    </div>
    <div class="px-10 pb-10">
      <div class="flex justify-between items-start">
        <div>
          <h3 class="text-3xl font-black"><%= user.name %></h3>
          <p class="text-slate-400 font-bold text-sm mt-1"><%= user.email %></p>
          <div class="inline-flex items-center gap-2 bg-[#E0ECF9] accent-text px-4 py-2 rounded-full mt-5 text-[11px] font-black uppercase tracking-widest">
            <i class="fa-solid fa-calendar-check"></i> Thành viên  <%= user.memberSince %>
          </div>
        </div>
        <div class="text-5xl bear-float pt-2">🐻</div>
      </div>
    </div>
</div>

<div class="grid grid-cols-4 gap-6 mb-10">
    <div class="stat-item bg-rose-50">
      <p class="text-rose-500 text-3xl font-black mb-1"><%= user.dayStreak %></p>
      <p class="text-[11px] font-black text-rose-300 uppercase tracking-tighter">Ngày liên tiếp</p>
    </div>
    <div class="stat-item bg-[#E0ECF9]">
      <p class="accent-text text-3xl font-black mb-1"><%= user.totalEntries %></p>
      <p class="text-[11px] font-black accent-text uppercase tracking-tighter">Tổng số bài</p>
    </div>
    <div class="stat-item bg-emerald-50">
      <p class="text-emerald-500 text-3xl font-black mb-1"><%= user.daysJournaled %></p>
      <p class="text-[11px] font-black text-emerald-300 uppercase tracking-tighter">Ngày viết</p>
    </div>
    <div class="stat-item bg-yellow-50">
      <p class="text-yellow-600 text-3xl font-black mb-1"><%= user.starredEntries %></p>
      <p class="text-[11px] font-black text-yellow-400 uppercase tracking-tighter">Đã gắn sao</p>
    </div>
</div>

<div class="profile-card-main p-8">
    <h4 class="text-[12px] font-black accent-text uppercase tracking-[0.2em] mb-6 ml-4">Cài đặt tài khoản</h4>
    <div class="space-y-1">
      <div class="setting-row group cursor-pointer" id="editProfileBtn">
        <div class="flex items-center gap-5">
          <div class="icon-wrap bg-blue-50 text-blue-500 group-hover:scale-110 transition-all"><i class="fa-solid fa-user-pen"></i></div>
          <div>
            <p class="font-extrabold text-slate-700">Chỉnh sửa hồ sơ</p>
            <p class="text-[11px] text-slate-400 font-bold">Tên, email và tiểu sử</p>
          </div>
        </div>
        <i class="fa-solid fa-chevron-right text-slate-200 text-xs"></i>
      </div>

      <div class="setting-row group">
        <div class="flex items-center gap-5">
          <div class="icon-wrap bg-emerald-50 text-emerald-500 group-hover:scale-110 transition-all">
  <i class="fa-solid fa-mobile-screen-button"></i>
</div>
          <div>
            <p class="font-extrabold text-slate-700">Xác thực 2 lớp (2FA)</p>
            <p class="text-[11px] text-slate-400 font-bold" id="2fa-status-text">
                <%= user.isTwoFactorEnabled ? '🛡️ Đã bảo vệ' : 'Chưa kích hoạt' %>
            </p>
          </div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="2fa-toggle" class="sr-only peer" <%= user.isTwoFactorEnabled ? 'checked' : '' %>>
          <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer dark:bg-slate-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-emerald-500"></div>
        </label>
      </div>

      <div class="setting-row group cursor-pointer" id="changePasswordBtn">
        <div class="flex items-center gap-5">
          <div class="icon-wrap bg-purple-50 text-purple-500 group-hover:scale-110 transition-all"><i class="fa-solid fa-shield-halved"></i></div>
          <div>
            <p class="font-extrabold text-slate-700">Bảo mật</p>
            <p class="text-[11px] text-slate-400 font-bold">Lần cuối đổi: <%= user.passwordChangedAt || 'Chưa đổi mật khẩu' %></p>
          </div>
        </div>
        <i class="fa-solid fa-chevron-right text-slate-200 text-xs"></i>
      </div>

      <div class="setting-row">
        <div class="flex items-center gap-5">
          <div class="icon-wrap bg-blue-50 text-blue-500"><i class="fa-solid fa-laptop-code"></i></div>
          <div>
            <p class="font-extrabold text-slate-700">Đăng nhập gần nhất</p>
            <p class="text-[11px] text-slate-400 font-bold"><%= user.lastLoginDevice || 'Thiết bị này' %></p>
          </div>
        </div>
        <div class="text-[10px] font-bold text-slate-400"><%= user.lastLoginTime || 'Vừa xong' %></div>
      </div>

      <div class="setting-row">
        <div class="flex items-center gap-5">
          <div class="icon-wrap bg-yellow-50 text-yellow-500"><i class="fa-solid fa-circle-half-stroke"></i></div>
          <div>
            <p class="font-extrabold text-slate-700">Giao diện</p>
            <p class="text-[11px] text-slate-400 font-bold">Chế độ tối và chủ đề</p>
          </div>
        </div>
        <div class="text-sm font-bold text-slate-500" id="appearanceStatus">☀️ Sáng</div>
      </div>

      <div class="setting-row group cursor-pointer" id="themePickerBtn">
        <div class="flex items-center gap-5">
          <div class="icon-wrap bg-violet-50 text-violet-500 group-hover:scale-110 transition-all"><i class="fa-solid fa-palette"></i></div>
          <div>
            <p class="font-extrabold text-slate-700">Đổi chủ đề</p>
            <p class="text-[11px] text-slate-400 font-bold">Chọn màu sắc yêu thích</p>
          </div>
        </div>
        <i class="fa-solid fa-chevron-right text-slate-200 text-xs"></i>
      </div>
    </div>
</div>

<div id="changePasswordModal" class="hidden fixed inset-0 bg-black/50 items-center justify-center z-[100] p-4 backdrop-blur-sm">
    <div class="bg-white dark:bg-slate-800 w-full max-w-md p-8 rounded-[2.5rem] shadow-2xl border border-blue-50 relative modal-animate">
        <div class="text-center mb-6">
            <div class="text-4xl mb-3">🔑</div>
            <h3 class="text-2xl font-black text-[#1E3A8A] dark:text-white">Đổi mật khẩu</h3>
            <p class="text-slate-400 text-sm font-bold">Nhập thông tin để cập nhật mật khẩu 🐻</p>
        </div>

        <form action="/auth/change-password" method="POST" class="space-y-4">
            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1 ml-1">Mật khẩu hiện tại</label>
                <input type="password" name="currentPassword" placeholder="••••••••" class="w-full bg-[#F8FBFF] dark:bg-slate-700 border border-[#EBF4FF] dark:border-slate-600 rounded-2xl p-4 outline-none focus:border-blue-500 dark:text-white" required>
            </div>
            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1 ml-1">Mật khẩu mới</label>
                <input type="password" name="newPassword" placeholder="••••••••" class="w-full bg-[#F8FBFF] dark:bg-slate-700 border border-[#EBF4FF] dark:border-slate-600 rounded-2xl p-4 outline-none focus:border-blue-500 dark:text-white" required>
            </div>
            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1 ml-1">Xác nhận mật khẩu</label>
                <input type="password" name="confirmNewPassword" placeholder="••••••••" class="w-full bg-[#F8FBFF] dark:bg-slate-700 border border-[#EBF4FF] dark:border-slate-600 rounded-2xl p-4 outline-none focus:border-blue-500 dark:text-white" required>
            </div>

            <div class="flex gap-3 pt-4">
                <button type="button" id="closePwdModal" class="flex-1 py-4 text-slate-400 font-bold hover:text-slate-600 transition-colors">Hủy bỏ</button>
                <button type="submit" class="flex-1 bg-blue-500 hover:bg-blue-600 text-white py-4 rounded-2xl font-black shadow-lg transition-all">Lưu 🐻</button>
            </div>
        </form>
    </div>
</div>

<div id="themePicker" class="hidden fixed inset-0 bg-transparent flex items-center justify-center z-50">
    <div class="bg-white rounded-3xl p-8 w-[420px] shadow-2xl border border-slate-100">
      <h3 class="text-lg font-bold text-center mb-6 primary-text">Chọn chủ đề màu</h3>
      <div class="grid grid-cols-5 gap-6">
          <div data-theme="blue" class="theme-swatch w-12 h-12 rounded-2xl bg-[#5A9BD4] cursor-pointer hover:scale-110 transition-transform shadow"></div>
          <div data-theme="pink" class="theme-swatch w-12 h-12 rounded-2xl bg-[#F8B4D9] cursor-pointer hover:scale-110 transition-transform shadow"></div>
          <div data-theme="green" class="theme-swatch w-12 h-12 rounded-2xl bg-[#A8E6CF] cursor-pointer hover:scale-110 transition-transform shadow"></div>
          <div data-theme="purple" class="theme-swatch w-12 h-12 rounded-2xl bg-[#D4B3FF] cursor-pointer hover:scale-110 transition-transform shadow"></div>
          <div data-theme="yellow" class="theme-swatch w-12 h-12 rounded-2xl bg-[#F9D77E] cursor-pointer hover:scale-110 transition-transform shadow"></div>
      </div>
      <div class="text-center mt-8">
        <button id="themePickerCloseBtn" class="px-8 py-3 text-sm font-bold text-slate-500 hover:text-slate-700">Đóng</button>
      </div>
    </div>
</div>

<div class="text-center py-10 opacity-40">
    <p class="text-[10px] font-black uppercase tracking-[0.3em]">Moodiary v1.0.4</p>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
      // 1. Giao diện sáng tối
      const currentTheme = document.documentElement.getAttribute('data-theme');
      const statusEl = document.getElementById('appearanceStatus');
      if (statusEl && currentTheme) {
        statusEl.innerHTML = currentTheme === 'dark' ? '🌙 Tối' : '☀️ Sáng';
      }

      // 2. Chỉnh sửa hồ sơ
      const editBtn = document.getElementById('editProfileBtn');
      if (editBtn) {
        editBtn.addEventListener('click', () => window.location.href = '/diaries/profile/edit');
      }

      // 3. XỬ LÝ NÚT GẠT 2FA
      const twoFactorToggle = document.getElementById('2fa-toggle');
      const statusText = document.getElementById('2fa-status-text');

      window.showNotification = function(message, type = 'info') {
          const oldNotif = document.querySelector('.custom-notification');
          if (oldNotif) oldNotif.remove();
          
          const notification = document.createElement('div');
          notification.className = 'custom-notification';
          if (type === 'success') {
              notification.style.backgroundColor = '#10B981';
          } else if (type === 'error') {
              notification.style.backgroundColor = '#EF4444';
          } else {
              notification.style.backgroundColor = '#3B82F6';
          }
          notification.style.color = 'white';
          notification.textContent = message;
          document.body.appendChild(notification);
          setTimeout(() => {
              notification.style.animation = 'slideOutRight 0.3s ease';
              setTimeout(() => notification.remove(), 300);
          }, 3000);
      };

      if (twoFactorToggle) {
          let isUpdating = false;
          twoFactorToggle.addEventListener('change', async function() {
            if (isUpdating) return;
            if (this.checked) {
              window.location.href = '/auth/setup-2fa';
              return;
            }
            const confirmDisable = confirm('Bạn có chắc chắn muốn tắt bảo mật 2 lớp không?');
            if (!confirmDisable) {
              this.checked = true;
              return;
            }
            isUpdating = true;
            try {
              const response = await fetch('/auth/disable-2fa', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
              });
              const data = await response.json();
              if (data.ok) {
                window.showNotification('Đã tắt xác thực 2 lớp!', 'success');
                setTimeout(() => window.location.reload(), 600);
              } else {
                this.checked = true;
                window.showNotification(data.error || 'Có lỗi xảy ra!', 'error');
              }
            } catch (error) {
              this.checked = true;
              window.showNotification('Lỗi kết nối!', 'error');
            } finally {
              isUpdating = false;
            }
          });
      }

      // 4. XỬ LÝ MODAL ĐỔI MẬT KHẨU
      const pwdBtn = document.getElementById('changePasswordBtn');
      const pwdModal = document.getElementById('changePasswordModal');
      const closePwdBtn = document.getElementById('closePwdModal');

      if (pwdBtn && pwdModal) {
        pwdBtn.addEventListener('click', () => {
          pwdModal.style.display = 'flex'; // Hiện modal
        });
      }

      if (closePwdBtn) {
        closePwdBtn.addEventListener('click', () => {
          pwdModal.style.display = 'none'; // Đóng modal
        });
      }

      // Đóng khi click ra ngoài vùng trắng
      window.addEventListener('click', (e) => {
        if (e.target === pwdModal) {
          pwdModal.style.display = 'none';
        }
      });
      
      // 5. Theme picker
      const themePickerBtn = document.getElementById('themePickerBtn');
      const themePickerModal = document.getElementById('themePicker');
      const themeClose = document.getElementById('themePickerCloseBtn');
      if (themePickerBtn) {
        themePickerBtn.addEventListener('click', () => themePickerModal.classList.toggle('hidden'));
      }
      if (themeClose) {
        themeClose.addEventListener('click', () => themePickerModal.classList.add('hidden'));
      }
      
      // Đóng popup theme khi nhấn ra ngoài
      window.addEventListener('click', (e) => {
        if (e.target === themePickerModal) {
          themePickerModal.classList.add('hidden');
        }
      });

      document.querySelectorAll('.theme-swatch').forEach(el => {
        el.addEventListener('click', (ev) => {
          ev.stopPropagation();
          const t = el.getAttribute('data-theme');
          if (t) {
            localStorage.setItem('moodiary-theme', t);
            if (window.setTheme) window.setTheme(t);
          }
          themePickerModal.classList.add('hidden');
        });
      });
    });
</script>