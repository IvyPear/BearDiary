<% title = 'Cá nhân - Bear Diary'; %>
<% 
  // Dữ liệu Server-side an toàn
  var lastLoginData = (user && user.lastLogin) ? new Date(user.lastLogin).toISOString() : null;
  var lastLoginJSON = JSON.stringify(lastLoginData);
%>

<style>
    /* 1. Cấu trúc thẻ chính: Thêm Margin Bottom để các phần không dính nhau */
    .profile-card-main {
      background: white; border-radius: 2.5rem; overflow: hidden;
      border: 1px solid var(--card-border); box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
      margin-bottom: 2rem; /* Tạo khoảng cách dưới card */
    }
    .banner-box { height: 160px; background: var(--banner); position: relative; }

    /* 2. Avatar Container: Căn chỉnh lại shadow và viền */
    .avatar-container {
      width: 110px; height: 110px; background: #DBEAFE; border: 6px solid white;
      border-radius: 2.5rem; display: flex; align-items: center; justify-content: center;
      font-size: 32px; font-weight: 900; color: var(--accent); margin-top: -55px;
      margin-left: 40px; position: relative; z-index: 10; box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
      overflow: hidden;
    }
    .avatar-container img { width: 100%; height: 100%; object-fit: cover; }
    .avatar-fallback {
      width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;
    }

    /* 3. Stat Items: Tăng Gap (khoảng cách giữa các ô) */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem; /* Khoảng cách giữa các ô thống kê */
      margin-bottom: 2.5rem;
    }
    .stat-item {
      border-radius: 1.8rem; padding: 26px 10px; text-align: center;
      transition: all 0.3s ease; background: white; border: 1px solid var(--card-border);
    }
    .stat-item:hover { transform: translateY(-5px); box-shadow: 0 12px 25px rgba(0,0,0,0.05); }

    /* 4. Cài đặt dòng (Setting Row): Tăng padding để nhìn thoáng hơn */
    .setting-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 20px 24px; border-radius: 1.5rem; cursor: pointer; transition: all 0.2s;
    }
    .setting-row:hover { background: #F8FAFF; }
    .icon-wrap { width: 46px; height: 46px; border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 18px; }

    /* Dark mode tinh chỉnh */
    [data-theme="dark"] .profile-card-main, [data-theme="dark"] .stat-item { background: #1E2937; border-color: #334155; }
    [data-theme="dark"] .setting-row:hover { background: #334155; }
    [data-theme="dark"] .text-slate-700 { color: #E2E8F0 !important; }
    [data-theme="dark"] .avatar-container { border-color: #1E2937; }

    /* Hiệu ứng chuyển Tab */
    .tab-view { transition: all 0.3s ease; }
    .hidden-tab { display: none !important; }
</style>

<div class="flex items-center gap-4 mb-10">
    <div class="w-12 h-12 flex items-center justify-center text-white text-xl shadow-lg rounded-2xl" style="background: var(--accent)">
      <i class="fa-solid fa-user-gear"></i>
    </div>
    <div>
      <h2 class="text-3xl font-black">Hồ sơ của tôi</h2>
      <p class="text-slate-400 font-bold text-sm">Quản lý tài khoản và phong cách</p>
    </div>
</div>

<div id="main-view" class="tab-view">
    <div class="profile-card-main">
        <div class="banner-box"></div>
        <div class="avatar-container">
          <% if (user.avatar && user.avatar !== 'U' && !user.avatar.match(/^[A-Z]$/)) { %>
            <img src="<%= user.avatar %>" alt="<%= user.name %>">
          <% } else { %>
            <div class="avatar-fallback"><%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %></div>
          <% } %>
        </div>
        <div class="px-10 pb-10">
          <div class="flex justify-between items-start mt-4">
            <div>
              <h3 class="text-3xl font-black text-slate-800 dark:text-white"><%= user.name %></h3>
              <p class="text-slate-400 font-bold text-sm mt-1"><%= user.email %></p>
              <div class="inline-flex items-center gap-2 bg-[#E0ECF9] dark:bg-blue-900/30 accent-text px-4 py-2 rounded-full mt-6 text-[11px] font-black uppercase tracking-widest">
                <i class="fa-solid fa-calendar-check"></i> Thành viên <%= user.memberSince %>
              </div>
            </div>
            <div class="text-6xl bear-float pt-2">🐻</div>
          </div>
        </div>
    </div>

    <div class="stat-grid">
        <div class="stat-item bg-rose-50/50 border-rose-100">
            <p class="text-rose-500 text-3xl font-black"><%= user.dayStreak %></p>
            <p class="text-[10px] font-black text-rose-300 uppercase mt-1">Ngày liên tiếp</p>
        </div>
        <div class="stat-item bg-[#E0ECF9]/50 border-blue-100">
            <p class="accent-text text-3xl font-black"><%= user.totalEntries %></p>
            <p class="text-[10px] font-black accent-text uppercase mt-1">Tổng số bài</p>
        </div>
        <div class="stat-item bg-emerald-50/50 border-emerald-100">
            <p class="text-emerald-500 text-3xl font-black"><%= user.daysJournaled %></p>
            <p class="text-[10px] font-black text-emerald-300 uppercase mt-1">Ngày viết</p>
        </div>
        <div class="stat-item bg-yellow-50/50 border-yellow-100">
            <p class="text-yellow-600 text-3xl font-black"><%= user.starredEntries %></p>
            <p class="text-[10px] font-black text-yellow-400 uppercase mt-1">Đã gắn sao</p>
        </div>
    </div>

    <div class="profile-card-main p-8 mt-4">
        <h4 class="text-[12px] font-black accent-text uppercase tracking-widest mb-6 ml-4">Cài đặt tài khoản</h4>
        <div class="space-y-2">
          <div class="setting-row group" id="editProfileBtn">
            <div class="flex items-center gap-5">
              <div class="icon-wrap bg-blue-50 text-blue-500"><i class="fa-solid fa-user-pen"></i></div>
              <div>
                <p class="font-extrabold text-slate-700 dark:text-slate-200">Chỉnh sửa hồ sơ</p>
                <p class="text-[11px] text-slate-400 font-bold">Tên, email và ảnh đại diện</p>
              </div>
            </div>
            <i class="fa-solid fa-chevron-right text-slate-200 group-hover:text-blue-400 transition-colors text-xs"></i>
          </div>

          <div class="setting-row group" id="openSecurityTabBtn">
            <div class="flex items-center gap-5">
              <div class="icon-wrap bg-purple-50 text-purple-500"><i class="fa-solid fa-shield-halved"></i></div>
              <div>
                <p class="font-extrabold text-slate-700 dark:text-slate-200">Bảo mật</p>
                <p class="text-[11px] text-slate-400 font-bold">Mật khẩu và xác thực</p>
              </div>
            </div>
            <i class="fa-solid fa-chevron-right text-slate-200 group-hover:text-purple-400 transition-colors text-xs"></i>
          </div>

          <div class="setting-row" id="toggleAppearanceBtn">
            <div class="flex items-center gap-5">
              <div class="icon-wrap bg-yellow-50 text-yellow-500"><i class="fa-solid fa-circle-half-stroke"></i></div>
              <div>
                <p class="font-extrabold text-slate-700 dark:text-slate-200">Giao diện</p>
                <p class="text-[11px] text-slate-400 font-bold">Chế độ sáng/tối</p>
              </div>
            </div>
            <div class="text-sm font-bold text-slate-500 bg-slate-100 dark:bg-slate-700 px-4 py-1 rounded-xl" id="appearanceStatus">☀️ Sáng</div>
          </div>

          <div class="setting-row group" id="themePickerBtn">
            <div class="flex items-center gap-5">
              <div class="icon-wrap bg-violet-50 text-violet-500"><i class="fa-solid fa-palette"></i></div>
              <div>
                <p class="font-extrabold text-slate-700 dark:text-slate-200">Đổi chủ đề</p>
                <p class="text-[11px] text-slate-400 font-bold">Chọn màu sắc yêu thích</p>
              </div>
            </div>
            <i class="fa-solid fa-chevron-right text-slate-200 group-hover:text-violet-400 transition-colors text-xs"></i>
          </div>
        </div>
    </div>
</div>

<div id="security-view" class="tab-view hidden-tab">
    <div class="profile-card-main p-8">
        <div class="flex items-center gap-4 mb-8">
            <button id="backToMainBtn" class="w-10 h-10 rounded-full hover:bg-slate-100 dark:hover:bg-slate-700 flex items-center justify-center text-slate-400 transition-colors">
                <i class="fa-solid fa-arrow-left"></i>
            </button>
            <h3 class="text-xl font-black text-slate-700 dark:text-white">Bảo mật tài khoản</h3>
        </div>

        <div class="space-y-2">
            <div class="setting-row group" id="changePasswordBtn">
                <div class="flex items-center gap-5">
                    <div class="icon-wrap bg-blue-50 text-blue-500"><i class="fa-solid fa-key"></i></div>
                    <div>
                        <p class="font-extrabold text-slate-700 dark:text-slate-200">Đổi mật khẩu</p>
                        <p class="text-[11px] text-slate-400 font-bold">Cập nhật mật khẩu mới</p>
                    </div>
                </div>
                <i class="fa-solid fa-chevron-right text-slate-200 text-xs"></i>
            </div>

            <div class="setting-row group">
                <div class="flex items-center gap-5">
                    <div class="icon-wrap bg-purple-50 text-purple-500"><i class="fa-solid fa-shield-halved"></i></div>
                    <div>
                        <p class="font-extrabold text-slate-700 dark:text-slate-200">Xác thực 2 yếu tố</p>
                        <p class="text-[11px] text-slate-400 font-bold" id="twoFaStatus">Chưa kích hoạt</p>
                    </div>
                </div>
                <button class="bg-blue-500 text-white px-4 py-1.5 rounded-xl text-[10px] font-black uppercase shadow-lg shadow-blue-500/20" id="toggle2FaBtn">Kích hoạt</button>
            </div>

            <div class="setting-row bg-slate-50/50 dark:bg-slate-800/50 cursor-default">
                <div class="flex items-center gap-5">
                    <div class="icon-wrap bg-yellow-50 text-yellow-500"><i class="fa-solid fa-clock"></i></div>
                    <div>
                        <p class="font-extrabold text-slate-700 dark:text-slate-200">Lần đăng nhập cuối</p>
                        <p class="text-[11px] text-slate-400 font-bold" id="lastLoginText">Đang tải...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="themePicker" class="hidden fixed inset-0 flex items-center justify-center z-50 bg-black/30 backdrop-blur-sm">
    <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 w-[420px] shadow-2xl scale-in-center">
        <h3 class="text-lg font-black text-center mb-6 dark:text-white">Chọn chủ đề màu</h3>
        <div class="grid grid-cols-5 gap-6">
            <div data-theme="blue" class="theme-swatch w-12 h-12 rounded-2xl bg-[#5A9BD4] cursor-pointer hover:scale-110 transition-transform"></div>
            <div data-theme="pink" class="theme-swatch w-12 h-12 rounded-2xl bg-[#F8B4D9] cursor-pointer hover:scale-110 transition-transform"></div>
            <div data-theme="green" class="theme-swatch w-12 h-12 rounded-2xl bg-[#A8E6CF] cursor-pointer hover:scale-110 transition-transform"></div>
            <div data-theme="purple" class="theme-swatch w-12 h-12 rounded-2xl bg-[#D4B3FF] cursor-pointer hover:scale-110 transition-transform"></div>
            <div data-theme="yellow" class="theme-swatch w-12 h-12 rounded-2xl bg-[#F9D77E] cursor-pointer hover:scale-110 transition-transform"></div>
        </div>
        <button id="themePickerCloseBtn" class="w-full mt-8 py-3 bg-slate-100 dark:bg-slate-700 rounded-2xl text-slate-500 dark:text-slate-300 font-black uppercase text-xs tracking-widest">Đóng</button>
    </div>
</div>

<script>
    // Khởi tạo dữ liệu từ Server
    window.userLastLogin = JSON.parse('<%- lastLoginJSON || "null" %>');

    document.addEventListener('DOMContentLoaded', function() {
        const mainView = document.getElementById('main-view');
        const securityView = document.getElementById('security-view');
        
        // Điều hướng nút bấm
        document.getElementById('editProfileBtn').addEventListener('click', () => {
            window.location.href = '/diaries/profile/edit';
        });

        document.getElementById('openSecurityTabBtn').addEventListener('click', () => {
            mainView.classList.add('hidden-tab');
            securityView.classList.remove('hidden-tab');
        });

        document.getElementById('backToMainBtn').addEventListener('click', () => {
            securityView.classList.add('hidden-tab');
            mainView.classList.remove('hidden-tab');
        });

        document.getElementById('changePasswordBtn').addEventListener('click', () => {
            window.location.href = '/diaries/profile/change-password';
        });

        // Xử lý Last Login
        const lastLoginEl = document.getElementById('lastLoginText');
        if (lastLoginEl && window.userLastLogin) {
            lastLoginEl.textContent = new Date(window.userLastLogin).toLocaleString('vi-VN');
        }

        // Logic 2FA giả lập
        document.getElementById('toggle2FaBtn').addEventListener('click', function() {
            const status = document.getElementById('twoFaStatus');
            if (this.textContent === 'Kích hoạt') {
                status.textContent = 'Đã kích hoạt';
                status.className = 'text-[11px] text-emerald-500 font-bold';
                this.textContent = 'Tắt';
                this.className = 'bg-rose-500 text-white px-4 py-1.5 rounded-xl text-[10px] font-black uppercase';
            } else {
                status.textContent = 'Chưa kích hoạt';
                status.className = 'text-[11px] text-slate-400 font-bold';
                this.textContent = 'Kích hoạt';
                this.className = 'bg-blue-500 text-white px-4 py-1.5 rounded-xl text-[10px] font-black uppercase';
            }
        });

        // Theme Picker logic
        const modal = document.getElementById('themePicker');
        document.getElementById('themePickerBtn').addEventListener('click', () => modal.classList.remove('hidden'));
        document.getElementById('themePickerCloseBtn').addEventListener('click', () => modal.classList.add('hidden'));

        document.querySelectorAll('.theme-swatch').forEach(el => {
            el.addEventListener('click', function() {
                const t = this.getAttribute('data-theme');
                if (window.setTheme) window.setTheme(t);
                localStorage.setItem('moodiary-theme', t);
                modal.classList.add('hidden');
            });
        });

        // Cập nhật trạng thái hiển thị Dark/Light
        const appearanceStatus = document.getElementById('appearanceStatus');
        if (appearanceStatus) {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            appearanceStatus.innerHTML = isDark ? '🌙 Tối' : '☀️ Sáng';
        }
    });
</script>

<div class="text-center py-10 opacity-30">
    <p class="text-[10px] font-black uppercase tracking-[0.3em] dark:text-white">Bear Diary v1.0.4</p>
</div>