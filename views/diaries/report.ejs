<%
  title = 'Mood Report - Moodiary';
  activePage = 'report';
%>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
  .report-icon {
    width: 52px;
    height: 52px;
    background: linear-gradient(135deg, var(--accent), #7EB8E8);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    color: white;
    box-shadow: 0 6px 20px rgba(90, 155, 212, 0.3);
  }

  .glass-card { 
    background: white; 
    border-radius: 2rem; 
    border: 1px solid var(--card-border); 
    box-shadow: 0 10px 40px rgba(0,0,0,0.04); 
  }

  .cal-day {
    aspect-ratio: 1/1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 1rem;
    font-weight: 700;
    font-size: 14px;
    position: relative;
    background: #FDFDFF;
    border: 1px solid #E0ECF9;
    transition: all 0.2s;
  }
  .cal-day.other-month { color: #9CA3AF; opacity: 0.6; }
  .cal-day.has-entry { background-size: cover; background-position: center; color: white; }
  .cal-day.today { 
    border: 2px solid var(--accent); 
    color: var(--accent); 
    font-weight: 800;
  }
  
  .important-star {
    position: absolute;
    top: -4px;
    right: -4px;
    color: #FBBF24;
    background: white;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    z-index: 10;
  }

  .stat-card {
    background: white;
    border-radius: 1.5rem;
    padding: 20px;
    text-align: center;
    border: 1px solid var(--card-border);
  }

  [data-theme="dark"] .glass-card { background: #1E2937; border-color: #334155; }
  [data-theme="dark"] .cal-day { background: #1E2937; border-color: #334155; color: #E2E8F0; }
  [data-theme="dark"] .stat-card { background: #1E2937; border-color: #334155; }
  [data-theme="dark"] .important-star { background: #1E2937; }
</style>

<div class="flex items-center gap-4 mb-8">
  <div class="report-icon">📊</div>
  <div>
    <h2 class="text-3xl font-black text-[#2C4A7C]">Mood Report</h2>
    <p class="text-slate-400 font-bold text-xs uppercase tracking-wider">INSIGHTS FROM YOUR JOURNAL</p>
  </div>
</div>

<!-- Month Navigation -->
<div class="glass-card p-4 mb-8 flex items-center justify-between">
  <button class="w-10 h-10 rounded-full hover:bg-[#F0F6FF] text-[#5A9BD4] transition-all">
    <i class="fa-solid fa-chevron-left"></i>
  </button>
  <div class="text-center">
    <h3 class="text-xl font-black">April 2026</h3>
    <p class="text-[10px] font-bold text-slate-400 uppercase">5 entries this month</p>
  </div>
  <button class="w-10 h-10 rounded-full hover:bg-[#F0F6FF] text-[#5A9BD4] transition-all">
    <i class="fa-solid fa-chevron-right"></i>
  </button>
</div>

<div class="grid grid-cols-12 gap-8 mb-8">
  <!-- Mood Distribution Chart -->
  <div class="col-span-5 glass-card p-8">
    <h4 class="font-bold text-lg mb-6 text-[#2C4A7C]">Mood Distribution</h4>
    <div class="relative mb-8">
      <canvas id="moodChart" height="250"></canvas>
    </div>
    <div class="space-y-3">
      <div class="flex justify-between items-center text-xs font-bold p-2 bg-slate-50 rounded-xl">
        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-yellow-400"></span> 😊 Happy</div>
        <span>2</span>
      </div>
      <div class="flex justify-between items-center text-xs font-bold p-2">
        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-emerald-400"></span> 😌 Calm</div>
        <span>1</span>
      </div>
      <div class="flex justify-between items-center text-xs font-bold p-2 bg-slate-50 rounded-xl">
        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-purple-400"></span> 🥳 Excited</div>
        <span>1</span>
      </div>
      <div class="flex justify-between items-center text-xs font-bold p-2">
        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-rose-400"></span> 😢 Sad</div>
        <span>1</span>
      </div>
    </div>
    <div class="mt-6 p-4 bg-[#E0ECF9] rounded-2xl text-center">
      <p class="text-[10px] font-bold text-[#5A9BD4] uppercase">Most Common Mood</p>
      <p class="text-lg font-black">😊 Happy</p>
    </div>
  </div>

  <!-- Calendar View -->
  <div class="col-span-7 glass-card p-8">
    <h4 class="font-bold text-lg mb-6 text-[#2C4A7C]">Calendar View</h4>
    
    <div class="grid grid-cols-7 gap-3 text-center mb-4">
      <span class="text-[10px] font-black text-[#5A9BD4] uppercase">Sun</span>
      <span class="text-[10px] font-black text-[#5A9BD4] uppercase">Mon</span>
      <span class="text-[10px] font-black text-[#5A9BD4] uppercase">Tue</span>
      <span class="text-[10px] font-black text-[#5A9BD4] uppercase">Wed</span>
      <span class="text-[10px] font-black text-[#5A9BD4] uppercase">Thu</span>
      <span class="text-[10px] font-black text-[#5A9BD4] uppercase">Fri</span>
      <span class="text-[10px] font-black text-[#5A9BD4] uppercase">Sat</span>
    </div>

    <div class="grid grid-cols-7 gap-3">
      <div class="cal-day other-month">29</div>
      <div class="cal-day other-month">30</div>
      <div class="cal-day other-month">31</div>
      <div class="cal-day bg-yellow-100/50">
        <div class="important-star"><i class="fa-solid fa-star"></i></div>
        <span class="text-yellow-600">1</span>
      </div>
      <div class="cal-day has-entry" style="background-image: url('https://images.unsplash.com/photo-1517842645767-c639042777db?w=100')">
        <div class="absolute inset-0 bg-black/30 rounded-2xl"></div>
        <span class="relative z-10">2</span>
      </div>
      <div class="cal-day has-entry" style="background-image: url('https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=100')">
        <div class="important-star"><i class="fa-solid fa-star"></i></div>
        <span class="relative z-10">3</span>
      </div>
      <div class="cal-day bg-emerald-50">4</div>

      <div class="cal-day has-entry" style="background-image: url('https://images.unsplash.com/photo-1501854140801-50d01698950b?w=100')">
        <div class="important-star"><i class="fa-solid fa-star"></i></div>
        <span class="relative z-10">5</span>
      </div>
      <div class="cal-day">6</div>
      <div class="cal-day">7</div>
      <div class="cal-day today">8</div>
      <div class="cal-day">9</div>
      <div class="cal-day">10</div>
      <div class="cal-day">11</div>

      <div class="cal-day">12</div>
      <div class="cal-day">13</div>
      <div class="cal-day">14</div>
      <div class="cal-day">15</div>
      <div class="cal-day">16</div>
      <div class="cal-day">17</div>
      <div class="cal-day">18</div>

      <div class="cal-day">19</div>
      <div class="cal-day">20</div>
      <div class="cal-day">21</div>
      <div class="cal-day">22</div>
      <div class="cal-day">23</div>
      <div class="cal-day">24</div>
      <div class="cal-day">25</div>

      <div class="cal-day">26</div>
      <div class="cal-day">27</div>
      <div class="cal-day">28</div>
      <div class="cal-day">29</div>
      <div class="cal-day">30</div>
      <div class="cal-day other-month">1</div>
      <div class="cal-day other-month">2</div>
    </div>

    <div class="mt-8 flex gap-6 text-[10px] font-bold text-slate-400">
      <div class="flex items-center gap-2"><span class="w-3 h-3 rounded border-2 border-[#5A9BD4]"></span> Today</div>
      <div class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-slate-100 border border-slate-200"></span> Has entry</div>
      <div class="flex items-center gap-2"><i class="fa-solid fa-star text-yellow-400"></i> Starred</div>
    </div>
  </div>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-4 gap-6">
  <div class="stat-card bg-[#E0ECF9]">
    <p class="text-3xl mb-1">📝</p>
    <h5 class="text-2xl font-black">12</h5>
    <p class="text-[10px] font-bold text-[#5A9BD4] uppercase">Total Entries</p>
  </div>
  <div class="stat-card bg-emerald-50">
    <p class="text-3xl mb-1">📅</p>
    <h5 class="text-2xl font-black">12</h5>
    <p class="text-[10px] font-bold text-emerald-500 uppercase">Days Journaled</p>
  </div>
  <div class="stat-card bg-yellow-50">
    <p class="text-3xl mb-1">⭐</p>
    <h5 class="text-2xl font-black">6</h5>
    <p class="text-[10px] font-bold text-yellow-600 uppercase">Starred Entries</p>
  </div>
  <div class="stat-card bg-purple-50">
    <p class="text-3xl mb-1">😊</p>
    <h5 class="text-2xl font-black">Happy</h5>
    <p class="text-[10px] font-bold text-purple-500 uppercase">Best Mood</p>
  </div>
</div>

<script>
  const ctx = document.getElementById('moodChart').getContext('2d');
  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Happy', 'Excited', 'Grateful', 'Calm', 'Sad'],
      datasets: [{
        data: [2, 1, 1, 1, 1],
        backgroundColor: ['#FBBF24', '#F87171', '#34D399', '#5A9BD4', '#94A3B8'],
        borderWidth: 0,
        hoverOffset: 20
      }]
    },
    options: {
      plugins: { legend: { display: false } },
      cutout: '70%',
      responsive: true,
      maintainAspectRatio: true
    }
  });
</script>