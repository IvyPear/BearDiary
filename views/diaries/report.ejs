<%
  title = 'Báo cáo cảm xúc - Bear Diary';
  activePage = 'report';
%>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

<style>
  .report-icon {
    width: 52px;
    height: 52px;
    background: linear-gradient(135deg, var(--accent), #7EB8E8);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    color: white;
    box-shadow: 0 6px 20px rgba(90, 155, 212, 0.3);
  }

  .glass-card { 
    background: white; 
    border-radius: 2rem; 
    border: 1px solid var(--card-border);
    box-shadow: 0 10px 40px rgba(0,0,0,0.04); 
  }

  .cal-day {
    aspect-ratio: 1/1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 1rem;
    font-weight: 700;
    font-size: 14px;
    position: relative;
    background: #FDFDFF;
    border: 1.5px solid #E2E8F0;
    transition: all 0.2s;
    cursor: pointer;
  }
  
  .cal-day.has-journal {
    border: 2px solid var(--accent);
    background: rgb(90, 155, 212);
}
  
  .cal-day.has-journal.has-image {
    background-size: cover;
    background-position: center;
    color: white;
    position: relative;
    border: 2px solid var(--accent);
}
  
  .cal-day.has-journal.has-image::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    border-radius: 0.9rem;
  }
  
  .cal-day.has-journal.has-image span {
    position: relative;
    z-index: 2;
  }
  
  .cal-day.no-journal {
    border: 1.5px solid #E2E8F0;
    background: #FDFDFF;
  }
  
  .cal-day.other-month { 
    color: #9CA3AF; 
    opacity: 0.6;
    border-color: #E2E8F0;
  }
  
  .cal-day.today { 
    border: 2.5px solid var(--accent, #5A9BD4); 
    color: var(--accent, #5A9BD4); 
    font-weight: 800;
    background: rgba(90, 155, 212, 0.08);
  }
  
  .important-star {
    position: absolute;
    top: -6px;
    right: -6px;
    color: #FBBF24;
    background: white;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    z-index: 15;
  }
  
  .cal-day.has-journal.has-image .important-star {
    background: rgba(0,0,0,0.6);
    color: #FBBF24;
  }

  .stat-card {
    background: white;
    border-radius: 1.5rem;
    padding: 20px;
    text-align: center;
    border: 1px solid var(--card-border);
  }

  [data-theme="dark"] .glass-card { background: #1E2937; border-color: #334155; }
  [data-theme="dark"] .cal-day { background: #1E2937; border-color: #334155; color: #E2E8F0; }
  [data-theme="dark"] .cal-day.has-journal { background: rgba(90, 155, 212, 0.15); }
  [data-theme="dark"] .stat-card { background: #1E2937; border-color: #334155; }
  [data-theme="dark"] .important-star { background: #1E2937; }
  [data-theme="dark"] .cal-day.has-journal.has-image .important-star { background: #1E2937; }
</style>

  <div class="flex items-center gap-4 mb-8">
  <div class="report-icon">📊</div>
  <div>
    <h2 class="text-3xl font-black primary-text">Báo cáo cảm xúc</h2>
    <p class="text-slate-400 font-bold text-xs uppercase tracking-wider">GÓC NHÌN TỪ NHẬT KÝ CỦA BẠN</p>
  </div>
</div>

  <div class="glass-card p-4 mb-8 flex items-center justify-between">
  <a href="/diaries/report?month=<%= prevMonth %>&year=<%= prevYear %>" class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-[#F0F6FF] accent-text transition-all">
    <i class="fa-solid fa-chevron-left"></i>
  </a>
  <div class="text-center">
    <h3 class="text-xl font-black">Tháng <%= currentMonth %>, <%= currentYear %></h3>
    <p class="text-[10px] font-bold text-slate-400 uppercase"><%= entriesCount %> bài viết trong tháng</p>
  </div>
  <a href="/diaries/report?month=<%= nextMonth %>&year=<%= nextYear %>" class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-[#F0F6FF] accent-text transition-all">
    <i class="fa-solid fa-chevron-right"></i>
  </a>
</div>

<div class="grid grid-cols-12 gap-8 mb-8">
  <div class="col-span-5 glass-card p-8 flex flex-col">
    <h4 class="font-bold text-lg mb-6 primary-text">Phân bố cảm xúc</h4>
    
    <% if (entriesCount > 0) { %>
      <div class="relative mb-6 flex-1">
        <canvas id="moodChart" height="250"></canvas>
      </div>
      <div class="mt-6 p-4 bg-[#E0ECF9] rounded-2xl text-center">
        <p class="text-[10px] font-bold accent-text uppercase">CẢM XÚC PHỔ BIẾN NHẤT</p>
        <p class="text-lg font-black"><%= topMood %></p>
      </div>
    <% } else { %>
      <div class="flex-1 flex flex-col items-center justify-center text-slate-400 min-h-[250px]">
        <i class="fa-solid fa-face-meh text-5xl mb-4 opacity-30"></i>
        <p class="font-bold text-sm">Chưa có dữ liệu cảm xúc</p>
        <p class="text-xs mt-1">Hãy viết nhật ký trong tháng này nhé!</p>
      </div>
    <% } %>
  </div>

  <div class="col-span-7 glass-card p-8">
    <h4 class="font-bold text-lg mb-6 primary-text">Lịch</h4>
    
    <div class="grid grid-cols-7 gap-3 text-center mb-4">
      <span class="text-[10px] font-black accent-text uppercase">CN</span>
      <span class="text-[10px] font-black accent-text uppercase">T2</span>
      <span class="text-[10px] font-black accent-text uppercase">T3</span>
      <span class="text-[10px] font-black accent-text uppercase">T4</span>
      <span class="text-[10px] font-black accent-text uppercase">T5</span>
      <span class="text-[10px] font-black accent-text uppercase">T6</span>
      <span class="text-[10px] font-black accent-text uppercase">T7</span>
    </div>

    <div class="grid grid-cols-7 gap-3">
      <% calendarDays.forEach(day => { %>
        <% 
          let classes = 'cal-day';
          if (day.isOtherMonth) classes += ' other-month no-journal';
          else if (!day.hasJournal) classes += ' no-journal';
          else {
            classes += ' has-journal';
            if (day.images && day.images.length > 0) classes += ' has-image';
          }
          if (day.isToday) classes += ' today';
        %>
        <div class="<%= classes %>" <%- (day.images && day.images.length > 0) ? `style="background-image: url('${day.images[0]}')"` : '' %>>
          <% if (day.isStarred) { %>
            <div class="important-star"><i class="fa-solid fa-star"></i></div>
          <% } %>
          <span><%= day.day %></span>
        </div>
      <% }) %>
    </div>

    <div class="mt-8 flex gap-6 text-[10px] font-bold text-slate-400">
      <div class="flex items-center gap-2"><span class="w-3 h-3 rounded border-2 accent-border"></span> Có nhật ký</div>
      <div class="flex items-center gap-2"><i class="fa-solid fa-star text-yellow-400"></i> Bài viết yêu thích</div>
      <div class="flex items-center gap-2"><span class="w-3 h-3 rounded border-2 accent-border bg-cover"></span> Có ảnh</div>
    </div>
  </div>
</div>

<div class="grid grid-cols-4 gap-6">
  <div class="stat-card bg-[#E0ECF9]">
    <p class="text-3xl mb-1">📝</p>
    <h5 class="text-2xl font-black"><%= totalEntries %></h5>
    <p class="text-[10px] font-bold accent-text uppercase">Tổng số bài viết</p>
  </div>
  <div class="stat-card bg-emerald-50">
    <p class="text-3xl mb-1">📅</p>
    <h5 class="text-2xl font-black"><%= entriesCount %></h5>
    <p class="text-[10px] font-bold text-emerald-500 uppercase">Bài trong tháng</p>
  </div>
  <div class="stat-card bg-yellow-50">
    <p class="text-3xl mb-1">⭐</p>
    <h5 class="text-2xl font-black"><%= totalStarred %></h5>
    <p class="text-[10px] font-bold text-yellow-600 uppercase">Bài viết yêu thích</p>
  </div>
  <div class="stat-card bg-purple-50">
    <p class="text-3xl mb-1">✨</p>
    <h5 class="text-lg font-black truncate px-2"><%= topMood === 'Chưa có dữ liệu' ? 'N/A' : topMood.split(' ')[0] %></h5>
    <p class="text-[10px] font-bold text-purple-500 uppercase">Cảm xúc nổi bật</p>
  </div>
</div>

<script>
  // Xử lý EJS trong nháy đơn để JS hiểu là string (không bị đỏ code ở VS Code)
  const entriesCount = Number('<%= entriesCount || 0 %>');

  // Chỉ vẽ Chart nếu tháng đó có bài viết
  if (entriesCount > 0) {
      const ctx = document.getElementById('moodChart').getContext('2d');
      
      const rawLabels = JSON.parse('<%- chartLabels || "[]" %>');
      const rawData = JSON.parse('<%- chartData || "[]" %>');
      
      const labels = rawLabels.map(l => l.substring(l.indexOf(' ') + 1) || l);
      const icons = rawLabels.map(l => l.split(' ')[0] || '');
      
      const colors = ['#FDE68A', '#FBCFE8', '#A7F3D0', '#BFDBFE', '#E9D5FF', '#FCA5A5', '#D8B4FE'];
      const primaryColor = getComputedStyle(document.documentElement).getPropertyValue('--primary-dark').trim() || '#2C4A7C';

      new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: labels,
          datasets: [{
            data: rawData,
            backgroundColor: colors.slice(0, rawData.length),
            borderWidth: 0,
            hoverOffset: 20
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          cutout: '60%',
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                font: { size: 11, weight: 'bold' },
                padding: 10,
                usePointStyle: true,
                pointStyle: 'circle',
                boxWidth: 8,
                generateLabels: (chart) => {
                  const data = chart.data;
                  const total = data.datasets[0].data.reduce((a, b) => a + b, 0);
                  
                  return data.labels.map((label, i) => {
                    const val = data.datasets[0].data[i];
                    const percent = ((val / total) * 100).toFixed(1);
                    return {
                      text: `${icons[i]} ${label} (${percent}%)`,
                      fillStyle: data.datasets[0].backgroundColor[i],
                      index: i,
                      hidden: false,
                      fontColor: primaryColor
                    };
                  });
                }
              }
            },
            tooltip: {
              callbacks: {
                label: (context) => {
                  const total = context.dataset.data.reduce((a, b) => a + b, 0);
                  const percent = ((context.raw / total) * 100).toFixed(1);
                  return `${icons[context.dataIndex]} ${context.label}: ${context.raw} bài (${percent}%)`;
                }
              }
            },
            datalabels: {
              color: primaryColor,
              font: { weight: 'bold', size: 13 },
              formatter: (value, context) => {
                const total = context.chart.data.datasets[0].data.reduce((a, b) => a + b, 0);
                return Math.round((value / total) * 100) + '%';
              },
              anchor: 'center',
              align: 'center',
              offset: 0,
              backgroundColor: 'rgba(255,255,255,0.85)',
              borderRadius: 20,
              padding: { left: 6, right: 6, top: 3, bottom: 3 }
            }
          }
        },
        plugins: [ChartDataLabels]
      });
  }

</script>
