<% title='Công việc - Bear Diary'; %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
:root {
  --t-bg: #F8FAFF;
  --t-card: #ffffff;
  --t-border: #E2E8F0;
  --t-text: #334155;
  --t-muted: #94A3B8;
  --t-accent: #5A9BD4;
  --t-accent2: #7EB8E8;
  --t-accent-rgb: 90,155,212;
  --t-success: #10B981;
  --t-warn: #F59E0B;
  --t-danger: #EF4444;
}

[data-theme="dark"] {
  --t-bg: #0F172A;
  --t-card: #1E293B;
  --t-border: #334155;
  --t-text: #F8FAFC;
  --t-muted: #94A3B8;
  --t-accent: #60A5FA;
  --t-accent2: #93C5FD;
  --t-accent-rgb: 96,165,250;
  --t-success: #34D399;
  --t-warn: #FBBF24;
  --t-danger: #F87171;
}

/* Color themes */
[data-theme="pink"] { --t-accent:#F472B6; --t-accent2:#FBCFE8; }
[data-theme="green"] { --t-accent:#34D399; --t-accent2:#A7F3D0; }
[data-theme="purple"] { --t-accent:#A78BFA; --t-accent2:#DDD6FE; }
[data-theme="yellow"] { --t-accent:#FBBF24; --t-accent2:#FDE68A; }

.task-page { background:var(--t-bg); min-height:100vh; color:var(--t-text); }
.task-container { max-width:1280px; margin:0 auto; padding:1rem; }

.banner-gradient {
  background: linear-gradient(135deg, var(--t-accent), var(--t-accent2));
  border-radius: 2rem;
  padding: 1.75rem 1.5rem;
  color: #fff;
  position: relative;
  overflow: hidden;
  margin-bottom: 1.5rem;
}
.banner-stat {
  background: rgba(255,255,255,0.22);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.3);
  border-radius: 1rem;
  padding: 0.5rem 0.75rem;
  text-align: center;
  min-width: 78px;
}
.banner-stat p:first-child { font-size: 0.75rem; opacity: 0.9; }
.banner-stat p:last-child { font-size: 1.4rem; font-weight: 800; }

.card {
  background: var(--t-card);
  border-radius: 1.75rem;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  border: 1px solid var(--t-border);
  overflow: hidden;
}
.card-header {
  padding: 1.1rem 1.5rem;
  border-bottom: 1px solid var(--t-border);
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.card-body { padding: 1.25rem; }

.filter-bar { display:flex; flex-wrap:wrap; gap:8px; }
.filter-chip {
  padding: 0.45rem 1rem;
  border-radius: 9999px;
  font-size: 0.82rem;
  font-weight: 600;
  border: 1px solid var(--t-border);
  background: var(--t-card);
  color: var(--t-muted);
  cursor: pointer;
  transition: all .2s;
}
.filter-chip.active {
  background: var(--t-accent) !important;
  color: #fff !important;
  border-color: var(--t-accent) !important;
}

.task-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.1rem 1.5rem;
  border-bottom: 1px solid var(--t-border);
  cursor: pointer;
  transition: background .2s;
}
.task-item:hover { background: rgba(var(--t-accent-rgb), 0.05); }
.task-item:last-child { border-bottom: none; }

.task-check {
  width: 26px; height: 26px;
  border: 2.5px solid var(--t-border);
  border-radius: 9px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  cursor: pointer;
  background: var(--t-card);
  margin-top: 2px;
}
.task-check.done { background: var(--t-accent); border-color: var(--t-accent); color: white; }
.task-check.inprog { background: var(--t-warn); border-color: var(--t-warn); color: white; }

.priority-badge {
  font-size: 0.73rem;
  padding: 3px 9px;
  border-radius: 9999px;
  font-weight: 700;
}
.priority-badge.high { background:#FEE2E2; color:#DC2626; }
.priority-badge.medium { background:#FEF3C7; color:#D97706; }
.priority-badge.low { background:#D1FAE5; color:#059669; }

[data-theme="dark"] .priority-badge.high { background:rgba(220,38,38,0.2); color:#FCA5A5; }
[data-theme="dark"] .priority-badge.medium { background:rgba(217,119,6,0.2); color:#FCD34D; }
[data-theme="dark"] .priority-badge.low { background:rgba(5,150,105,0.2); color:#6EE7B7; }

.deadline-pill {
  font-size: 0.75rem;
  padding: 4px 10px;
  border-radius: 9999px;
  font-weight: 600;
  white-space: nowrap;
}
.deadline-pill.ok { background:#ECFDF5; color:#059669; }
.deadline-pill.warn { background:#FFFBEB; color:#D97706; }
.deadline-pill.over { background:#FEF2F2; color:#DC2626; }

[data-theme="dark"] .deadline-pill.ok { background:rgba(5,150,105,0.15); color:#6EE7B7; }
[data-theme="dark"] .deadline-pill.warn { background:rgba(217,119,6,0.15); color:#FCD34D; }
[data-theme="dark"] .deadline-pill.over { background:rgba(220,38,38,0.15); color:#FCA5A5; }

.progress-bar {
  height: 6px;
  background: var(--t-border);
  border-radius: 9999px;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--t-accent);
  border-radius: 9999px;
  transition: width .4s;
}

.view-btn {
  padding: 0.5rem 1.1rem;
  border-radius: 9999px;
  font-size: 0.85rem;
  font-weight: 600;
  border: 1px solid var(--t-border);
  background: var(--t-card);
  color: var(--t-muted);
  cursor: pointer;
  transition: all .2s;
}
.view-btn.active {
  background: var(--t-accent) !important;
  color: #fff !important;
  border-color: var(--t-accent) !important;
}

.kanban-board {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1.25rem;
}
.kanban-col {
  background: var(--t-bg);
  border: 1px solid var(--t-border);
  border-radius: 1.5rem;
  padding: 1rem;
}

.fab-btn {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--t-accent), var(--t-accent2));
  color: white;
  font-size: 1.8rem;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 25px rgba(0,0,0,0.18);
  z-index: 100;
  transition: transform .2s;
}
.fab-btn:hover { transform: scale(1.08); }

.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(4px);
  z-index: 200;
  display: none;
  align-items: center;
  justify-content: center;
}
.modal-overlay.show { display: flex; }
.modal-content {
  background: var(--t-card);
  border-radius: 1.75rem;
  width: 100%;
  max-width: 520px;
  max-height: 92vh;
  overflow-y: auto;
  margin: 1rem;
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
}
</style>

<div class="task-page">
<div class="task-container">

  <!-- BANNER -->
  <div class="banner-gradient">
    <div class="flex justify-between items-center">
      <div>
        <p class="text-white/80 text-sm" id="tkDateLabel"></p>
        <h2 class="text-2xl md:text-3xl font-extrabold mt-1">Công việc của tôi 🐻</h2>
        <p class="text-white/75 text-sm mt-1">Quản lý công việc dễ dàng mỗi ngày</p>
      </div>
      <button onclick="tkAddTodayQuick()" class="bg-white/25 hover:bg-white/35 backdrop-blur px-5 py-2.5 rounded-2xl text-sm font-semibold transition flex items-center gap-2">
        <i class="fas fa-plus"></i> Thêm hôm nay
      </button>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-8">
      <div class="banner-stat"><p>Hôm nay</p><p id="statToday" class="text-3xl">0</p></div>
      <div class="banner-stat"><p>Hoàn thành tuần</p><p id="statDone" class="text-3xl">0</p></div>
      <div class="banner-stat"><p>Chuyển tiếp</p><p id="statCarry" class="text-3xl">0</p></div>
      <div class="banner-stat"><p>Tỉ lệ</p><p id="statPct" class="text-3xl">0%</p></div>
    </div>
  </div>

  <!-- FILTER -->
  <div class="card mb-6">
    <div class="card-body">
      <div class="flex flex-wrap gap-3 justify-between items-center">
        <div class="filter-bar" id="tkFilterBar">
          <button class="filter-chip active" data-filter="all">Tất cả</button>
          <button class="filter-chip" data-filter="today">Hôm nay</button>
          <button class="filter-chip" data-filter="week">Tuần này</button>
          <button class="filter-chip" data-filter="month">Tháng này</button>
          <button class="filter-chip" data-filter="starred">Quan trọng</button>
        </div>
        <div class="flex gap-2">
          <select id="tkMonthSelect" onchange="tkRender()" class="filter-chip">
            <option value="0">Tháng này</option>
            <option value="-1">Tháng trước</option>
          </select>
          <select id="tkYearSelect" onchange="tkRender()" class="filter-chip">
            <option value="2025">2025</option>
            <option value="2026" selected>2026</option>
            <option value="2027">2027</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <!-- VIEW SWITCH -->
  <div class="flex gap-3 mb-5">
    <button id="btnListView" onclick="tkSetView('list')" class="view-btn active">📋 Danh sách</button>
    <button id="btnKanbanView" onclick="tkSetView('kanban')" class="view-btn">📊 Kanban</button>
  </div>

  <!-- LIST VIEW -->
  <div id="tkListView">
    <!-- Hôm nay -->
    <div class="card mb-6">
      <div class="card-header">
        <i class="fas fa-sun text-accent"></i>
        <span>Hôm nay • <span id="tkTodayDateLabel"></span></span>
        <span class="ml-auto text-sm text-muted" id="tkTodayProgress"></span>
      </div>
      <div class="card-body pt-2">
        <div class="progress-bar mb-4"><div class="progress-fill" id="tkTodayBar" style="width:0%"></div></div>
        <div id="tkTodayList"></div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- Sắp tới -->
      <div class="card">
        <div class="card-header"><i class="fas fa-clock text-accent"></i> Sắp tới</div>
        <div class="card-body" id="tkUpcomingList"></div>
      </div>

      <!-- Đã hoàn thành -->
      <div class="card">
        <div class="card-header">
          <span><i class="fas fa-check-circle text-success"></i> Đã hoàn thành</span>
          <button onclick="tkToggleDoneList()" id="tkDoneToggle" class="ml-auto text-accent text-sm font-medium">Hiện</button>
        </div>
        <div class="card-body" id="tkDoneList" style="display:none"></div>
      </div>
    </div>
  </div>

  <!-- KANBAN VIEW -->
  <div id="tkKanbanView" style="display:none">
    <div class="kanban-board" id="tkKanbanBoard"></div>
  </div>

  <!-- BÁO CÁO TUẦN -->
  <div class="card mt-8">
    <div class="card-header">
      <i class="fas fa-chart-bar text-accent"></i>
      <span>Báo cáo tuần</span>
      <select id="tkWeekSelect" onchange="tkRenderReport()" class="filter-chip ml-auto">
        <option value="0">Tuần này</option>
        <option value="-1">Tuần trước</option>
      </select>
    </div>
    <div class="card-body" id="tkReportBody"></div>
  </div>

</div>
</div>

<!-- FAB -->
<button class="fab-btn" onclick="tkOpenModal()"><i class="fas fa-plus"></i></button>

<!-- MODAL -->
<div class="modal-overlay" id="tkOverlay" onclick="if(event.target===this)tkCloseModal()">
  <div class="modal-content" onclick="event.stopPropagation()">
    <div class="card-header border-b-0">
      <span id="tkModalTitle" class="text-xl">Thêm công việc</span>
      <button onclick="tkCloseModal()" class="ml-auto text-3xl leading-none text-muted">×</button>
    </div>
    <form id="tkForm" onsubmit="tkSaveTask(event)" class="card-body space-y-6">
      <input type="hidden" id="tkEditId">

      <div>
        <label class="block text-xs font-bold text-muted mb-1.5">TÊN CÔNG VIỆC *</label>
        <input type="text" id="tkName" required class="w-full px-4 py-3 border border-[var(--t-border)] rounded-2xl focus:outline-none focus:border-[var(--t-accent)]" placeholder="Nhập tên công việc...">
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-muted mb-1.5">DANH MỤC</label>
          <select id="tkCat" class="w-full px-4 py-3 border border-[var(--t-border)] rounded-2xl">
            <option value="study">📚 Học tập</option>
            <option value="code">💻 Code</option>
            <option value="personal">🙂 Cá nhân</option>
            <option value="other">📌 Khác</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-bold text-muted mb-1.5">DEADLINE</label>
          <input type="date" id="tkDeadline" class="w-full px-4 py-3 border border-[var(--t-border)] rounded-2xl">
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-muted mb-1.5">TRẠNG THÁI</label>
          <select id="tkStatus" class="w-full px-4 py-3 border border-[var(--t-border)] rounded-2xl">
            <option value="todo">Cần làm</option>
            <option value="inprog">Đang làm</option>
            <option value="done">Hoàn thành</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-bold text-muted mb-1.5">ƯU TIÊN</label>
          <div class="priority-select flex gap-2">
            <div class="priority-option low flex-1 py-2 text-center rounded-2xl border-2 cursor-pointer" data-priority="low">Thấp</div>
            <div class="priority-option medium flex-1 py-2 text-center rounded-2xl border-2 cursor-pointer" data-priority="medium">Trung bình</div>
            <div class="priority-option high flex-1 py-2 text-center rounded-2xl border-2 cursor-pointer selected" data-priority="high">Cao</div>
          </div>
          <input type="hidden" id="taskPriority" value="high">
        </div>
      </div>

      <div>
        <label class="block text-xs font-bold text-muted mb-1.5">TIẾN TRÌNH: <span id="tkProgLabel" class="text-accent">0%</span></label>
        <input type="range" id="tkProgress" min="0" max="100" step="5" value="0" class="w-full accent-[var(--t-accent)]">
      </div>

      <button type="submit" class="w-full py-4 bg-gradient-to-r from-[var(--t-accent)] to-[var(--t-accent2)] text-white font-bold rounded-2xl text-lg">💾 Lưu công việc</button>
    </form>
  </div>
</div>

<script>
// ==================== BEAR DIARY TASK MANAGER - CLEAN VERSION ====================
const STORE_KEY = 'bd_tasks_v3';
let tasks = JSON.parse(localStorage.getItem(STORE_KEY)) || [];
let activeFilter = 'all';
let currentView = 'list';
let showDone = false;

const saveTasks = () => localStorage.setItem(STORE_KEY, JSON.stringify(tasks));
const uid = () => Date.now().toString(36) + Math.random().toString(36).slice(2,8);
const todayStr = () => new Date().toISOString().slice(0,10);

const startOfWeek = (offset = 0) => {
  const d = new Date();
  d.setDate(d.getDate() - d.getDay() + 1 + offset * 7);
  d.setHours(0,0,0,0);
  return d;
};
const endOfWeek = (offset = 0) => {
  const d = startOfWeek(offset);
  d.setDate(d.getDate() + 6);
  d.setHours(23,59,59,999);
  return d;
};

// Priority & Status helpers
const priorityHTML = (p) => {
  if (p === 'high') return `<span class="priority-badge high"><i class="fas fa-arrow-up"></i> Cao</span>`;
  if (p === 'medium') return `<span class="priority-badge medium"><i class="fas fa-minus"></i> Trung</span>`;
  return `<span class="priority-badge low"><i class="fas fa-arrow-down"></i> Thấp</span>`;
};

const dlClass = (deadline, status) => {
  if (status === 'done') return 'ok';
  if (!deadline) return '';
  const diff = Math.ceil((new Date(deadline) - new Date(todayStr())) / 86400000);
  return diff < 0 ? 'over' : diff === 0 ? 'warn' : 'ok';
};

const dlLabel = (deadline, status) => {
  if (status === 'done') return 'Đã xong';
  if (!deadline) return '';
  const diff = Math.ceil((new Date(deadline) - new Date(todayStr())) / 86400000);
  if (diff < 0) return `Quá ${Math.abs(diff)} ngày`;
  if (diff === 0) return 'Hết hạn hôm nay';
  return `Còn ${diff} ngày`;
};

const catLabel = (c) => ({study:'📚 Học tập', code:'💻 Code', personal:'🙂 Cá nhân', other:'📌 Khác'}[c] || c);

// Render functions
const taskHTML = (tk) => {
  const pct = tk.progress || 0;
  return `
    <div class="task-item" onclick="tkOpenDetail('${tk.id}')">
      <div class="task-check ${tk.status==='done'?'done':tk.status==='inprog'?'inprog':''}" onclick="event.stopPropagation();tkToggleStatus('${tk.id}')">
        ${tk.status==='done' ? '<i class="fas fa-check"></i>' : tk.status==='inprog' ? '<i class="fas fa-ellipsis-h"></i>' : ''}
      </div>
      <div class="flex-1 min-w-0">
        <div class="font-semibold ${tk.status==='done'?'line-through text-muted':''}">${tk.name}</div>
        <div class="flex flex-wrap gap-2 mt-2">
          ${priorityHTML(tk.priority)}
          <span class="text-xs px-3 py-1 bg-[var(--t-border)] rounded-full">${catLabel(tk.cat)}</span>
          ${tk.deadline ? `<span class="deadline-pill ${dlClass(tk.deadline, tk.status)}">${dlLabel(tk.deadline, tk.status)}</span>` : ''}
        </div>
        ${pct > 0 && tk.status !== 'done' ? `
          <div class="mt-3">
            <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
            <div class="text-xs text-right text-muted mt-1">${pct}%</div>
          </div>` : ''}
      </div>
    </div>`;
};

window.tkRender = () => {
  const t = todayStr();
  const visible = tasks.filter(tk => {
    if (activeFilter === 'all') return true;
    if (activeFilter === 'today') return tk.deadline === t;
    if (activeFilter === 'week') {
      const sw = startOfWeek(0), ew = endOfWeek(0);
      return tk.deadline && new Date(tk.deadline) >= sw && new Date(tk.deadline) <= ew;
    }
    if (activeFilter === 'month') {
      const m = parseInt(document.getElementById('tkMonthSelect').value);
      const y = parseInt(document.getElementById('tkYearSelect').value);
      const now = new Date();
      const targetMonth = now.getMonth() + m;
      const targetYear = y;
      const start = new Date(targetYear, targetMonth, 1);
      const end = new Date(targetYear, targetMonth + 1, 0);
      return tk.deadline && new Date(tk.deadline) >= start && new Date(tk.deadline) <= end;
    }
    if (activeFilter === 'starred') return tk.starred === true;
    return true;
  });

  // Stats
  const todayTasks = tasks.filter(tk => tk.deadline === t);
  const doneWeek = tasks.filter(tk => tk.status === 'done' && tk.completedAt && new Date(tk.completedAt) >= startOfWeek(0) && new Date(tk.completedAt) <= endOfWeek(0)).length;
  const carry = tasks.filter(tk => tk.status !== 'done' && tk.deadline && new Date(tk.deadline) < new Date(t)).length;
  const total = tasks.length;
  const doneTotal = tasks.filter(tk => tk.status === 'done').length;

  document.getElementById('statToday').textContent = todayTasks.length;
  document.getElementById('statDone').textContent = doneWeek;
  document.getElementById('statCarry').textContent = carry;
  document.getElementById('statPct').textContent = total ? Math.round(doneTotal/total*100) + '%' : '0%';

  // Today section
  const todayDone = todayTasks.filter(tk => tk.status === 'done').length;
  const todayPct = todayTasks.length ? Math.round(todayDone / todayTasks.length * 100) : 0;
  document.getElementById('tkTodayProgress').innerHTML = `${todayDone}/${todayTasks.length} xong`;
  document.getElementById('tkTodayBar').style.width = todayPct + '%';

  // Render lists
  document.getElementById('tkTodayList').innerHTML = tasks.filter(tk => tk.deadline === t && tk.status !== 'done').map(taskHTML).join('') || '<div class="empty-state py-12 text-center text-muted">Không có công việc hôm nay</div>';

  document.getElementById('tkUpcomingList').innerHTML = visible.filter(tk => tk.status !== 'done' && (!tk.deadline || tk.deadline > t)).map(taskHTML).join('') || '<div class="empty-state py-12 text-center text-muted">Không có việc sắp tới</div>';

  document.getElementById('tkDoneList').innerHTML = visible.filter(tk => tk.status === 'done').map(taskHTML).join('') || '<div class="empty-state py-12 text-center text-muted">Chưa có việc hoàn thành</div>';

  if (currentView === 'kanban') renderKanban(visible);
  tkRenderReport();
};

const renderKanban = (visible) => {
  const cols = {todo: [], inprog: [], done: []};
  visible.forEach(tk => cols[tk.status || 'todo'].push(tk));

  let html = '';
  ['todo','inprog','done'].forEach(status => {
    const label = status==='todo'?'Cần làm':status==='inprog'?'Đang làm':'Hoàn thành';
    const color = status==='todo'?'var(--t-accent)':status==='inprog'?'#F59E0B':'#10B981';
    html += `
      <div class="kanban-col">
        <div class="font-bold mb-4 flex justify-between" style="color:${color}">
          ${label} <span class="bg-[var(--t-border)] px-3 py-0.5 rounded-full text-xs">${cols[status].length}</span>
        </div>
        ${cols[status].map(tk => `
          <div class="bg-[var(--t-card)] border border-[var(--t-border)] rounded-2xl p-4 mb-3 cursor-grab" draggable="true" ondragstart="tkDragStart(event,'${tk.id}')">
            <div class="font-medium">${tk.name}</div>
            <div class="text-xs text-muted mt-2">${catLabel(tk.cat)}</div>
          </div>
        `).join('')}
      </div>`;
  });
  document.getElementById('tkKanbanBoard').innerHTML = html;
};

window.tkSetView = (view) => {
  currentView = view;
  document.getElementById('tkListView').style.display = view === 'list' ? 'block' : 'none';
  document.getElementById('tkKanbanView').style.display = view === 'kanban' ? 'block' : 'none';
  document.getElementById('btnListView').classList.toggle('active', view==='list');
  document.getElementById('btnKanbanView').classList.toggle('active', view==='kanban');
  tkRender();
};

window.tkToggleStatus = (id) => {
  const tk = tasks.find(t => t.id === id);
  if (!tk) return;
  const cycle = {todo: 'inprog', inprog: 'done', done: 'todo'};
  tk.status = cycle[tk.status] || 'todo';
  if (tk.status === 'done') {
    tk.progress = 100;
    tk.completedAt = new Date().toISOString();
  }
  saveTasks();
  tkRender();
};

window.tkOpenModal = () => {
  document.getElementById('tkForm').reset();
  document.getElementById('tkEditId').value = '';
  document.getElementById('tkModalTitle').textContent = 'Thêm công việc mới';
  document.getElementById('tkDeadline').value = todayStr();
  document.getElementById('tkOverlay').classList.add('show');
};

window.tkCloseModal = () => {
  document.getElementById('tkOverlay').classList.remove('show');
};

window.tkSaveTask = (e) => {
  e.preventDefault();
  const id = document.getElementById('tkEditId').value;
  const task = {
    id: id || uid(),
    name: document.getElementById('tkName').value.trim(),
    cat: document.getElementById('tkCat').value,
    status: document.getElementById('tkStatus').value,
    deadline: document.getElementById('tkDeadline').value,
    progress: parseInt(document.getElementById('tkProgress').value) || 0,
    priority: document.getElementById('taskPriority').value,
    createdAt: id ? tasks.find(t=>t.id===id)?.createdAt || new Date().toISOString() : new Date().toISOString(),
    completedAt: null
  };

  if (task.progress >= 100) task.status = 'done';
  if (task.status === 'done') task.completedAt = new Date().toISOString();

  if (id) {
    const idx = tasks.findIndex(t => t.id === id);
    if (idx !== -1) tasks[idx] = task;
  } else {
    tasks.unshift(task);
  }

  saveTasks();
  tkCloseModal();
  tkRender();
};

window.tkAddTodayQuick = () => {
  document.getElementById('tkDeadline').value = todayStr();
  tkOpenModal();
};

// Priority selector
document.querySelectorAll('.priority-option').forEach(opt => {
  opt.addEventListener('click', function() {
    document.querySelectorAll('.priority-option').forEach(o => o.classList.remove('selected'));
    this.classList.add('selected');
    document.getElementById('taskPriority').value = this.dataset.priority;
  });
});

// Range input
document.getElementById('tkProgress').addEventListener('input', function() {
  document.getElementById('tkProgLabel').textContent = this.value + '%';
});

window.tkToggleDoneList = () => {
  showDone = !showDone;
  const el = document.getElementById('tkDoneList');
  el.style.display = showDone ? 'block' : 'none';
  document.getElementById('tkDoneToggle').textContent = showDone ? 'Ẩn' : 'Hiện';
};

window.tkRenderReport = () => {
  // Báo cáo tuần đơn giản
  const offset = parseInt(document.getElementById('tkWeekSelect').value) || 0;
  const sw = startOfWeek(offset);
  const doneThisWeek = tasks.filter(tk => tk.status === 'done' && tk.completedAt && new Date(tk.completedAt) >= sw && new Date(tk.completedAt) <= endOfWeek(offset)).length;

  document.getElementById('tkReportBody').innerHTML = `
    <div class="text-center py-8">
      <div class="text-5xl font-bold text-accent">${doneThisWeek}</div>
      <div class="text-muted mt-2">công việc đã hoàn thành trong tuần</div>
    </div>
  `;
};

// Drag & Drop cơ bản (có thể mở rộng sau)
window.tkDragStart = (e, id) => { e.dataTransfer.setData('text', id); };

document.getElementById('tkFilterBar').addEventListener('click', (e) => {
  if (e.target.classList.contains('filter-chip')) {
    document.querySelectorAll('#tkFilterBar .filter-chip').forEach(b => b.classList.remove('active'));
    e.target.classList.add('active');
    activeFilter = e.target.dataset.filter;
    tkRender();
  }
});

// Init
document.getElementById('tkDateLabel').textContent = new Date().toLocaleDateString('vi-VN', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
document.getElementById('tkTodayDateLabel').textContent = new Date().toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit' });

tkRender();
</script>