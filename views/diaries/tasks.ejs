<% title = 'Công việc - Bear Diary' %>

<div class="max-w-6xl mx-auto pb-20">
    <div class="banner-gradient rounded-[2rem] p-6 md:p-8 text-white flex items-center justify-between mb-8 shadow-xl relative overflow-hidden">
        <div>
            <h2 class="text-3xl font-black mb-2"><i class="fa-solid fa-list-check opacity-80 mr-2"></i> Công việc của tôi</h2>
            <p class="text-white/90 text-sm font-bold" id="todayHeaderLabel">Đang tải ngày...</p>
        </div>
        <div class="text-6xl md:text-7xl bear-float select-none">🐻</div>
    </div>

    <div class="bg-white rounded-[1.5rem] p-5 md:p-6 shadow-lg border border-slate-100 mb-8 card-shadow transition-all" id="taskFormContainer">
        <div class="flex justify-between items-center mb-4 border-b border-slate-100 pb-3">
            <div class="flex gap-4">
                <button class="add-tab-btn active text-sm font-bold pb-2 border-b-2 border-[var(--accent)] accent-text" data-mode="today">
                    <i class="fa-solid fa-bolt"></i> Việc hôm nay
                </button>
                <button class="add-tab-btn text-sm font-bold pb-2 border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition" data-mode="week">
                    <i class="fa-regular fa-calendar-days"></i> Lên lịch tuần
                </button>
            </div>
            <span id="editModeBadge" class="hidden bg-amber-100 text-amber-600 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">
                Đang chỉnh sửa
            </span>
        </div>

        <form id="taskForm" onsubmit="tkSaveTask(event)">
            <input type="hidden" id="tkEditId" value="">
            
            <div id="weeklyDatePicker" class="hidden mb-4">
                <div class="flex items-center justify-between mb-2">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Chọn ngày trong tuần</p>
                    <div class="flex items-center gap-2 bg-slate-50 border border-slate-200 px-2 py-1 rounded-lg">
                        <i class="fa-solid fa-magnifying-glass text-slate-400 text-xs"></i>
                        <input type="date" id="weekRefDate" onchange="renderWeekDays(this.value)" class="text-xs font-bold text-slate-500 bg-transparent outline-none cursor-pointer">
                    </div>
                </div>
                <div class="flex gap-2 overflow-x-auto pb-2" id="weekDaysContainer"></div>
                <input type="hidden" id="tkDate" required>
            </div>

            <div class="flex flex-col md:flex-row gap-3">
                <div class="flex-1">
                    <input type="text" id="tkName" required placeholder="Tên công việc (VD: Đọc xong chương 3)..." 
                           class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 outline-none focus:border-[var(--accent)] font-bold text-slate-600 placeholder:text-slate-400">
                </div>
                <div class="w-full md:w-48 flex-shrink-0">
                    <select id="tkPri" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 outline-none focus:border-[var(--accent)] font-bold text-slate-500 cursor-pointer">
                        <option value="high">🔴 Mục tiêu (Cao)</option>
                        <option value="med" selected>🟡 Bình thường</option>
                        <option value="low">🟢 Rảnh rỗi (Thấp)</option>
                    </select>
                </div>
                <div class="flex gap-2 w-full md:w-auto">
                    <button type="button" id="cancelEditBtn" onclick="tkCancelEdit()" class="hidden bg-slate-100 text-slate-500 font-bold px-5 py-3 rounded-xl hover:bg-slate-200 transition">
                        Hủy
                    </button>
                    <button type="submit" id="submitTaskBtn" class="flex-1 md:flex-none accent-bg text-white font-bold px-8 py-3 rounded-xl shadow-md hover:opacity-90 transition whitespace-nowrap flex items-center justify-center gap-2">
                        <i class="fa-solid fa-plus"></i> Thêm
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100 flex flex-wrap items-center gap-3 card-shadow">
                <div class="flex gap-2 flex-wrap">
                    <button class="filter-pill active" data-filter="all">Tất cả</button>
                    <button class="filter-pill" data-filter="today">Hôm nay</button>
                    <button class="filter-pill" data-filter="week">Tuần này</button>
                    <button class="filter-pill" data-filter="done">Đã hoàn thành</button>
                    <button class="filter-pill" data-filter="overdue">Quá hạn</button>
                </div>
                <div class="h-6 w-[1px] bg-slate-200 hidden md:block mx-2"></div>
                <div class="flex gap-2 w-full md:w-auto">
                    <select id="filterMonth" class="filter-select flex-1" onchange="tkRender()">
                        <option value="">-- Tháng --</option>
                        <option value="1">Tháng 1</option><option value="2">Tháng 2</option><option value="3">Tháng 3</option>
                        <option value="4">Tháng 4</option><option value="5">Tháng 5</option><option value="6">Tháng 6</option>
                        <option value="7">Tháng 7</option><option value="8">Tháng 8</option><option value="9">Tháng 9</option>
                        <option value="10">Tháng 10</option><option value="11">Tháng 11</option><option value="12">Tháng 12</option>
                    </select>
                    <select id="filterYear" class="filter-select flex-1" onchange="tkRender()">
                        <option value="">-- Năm --</option>
                        <option value="2024">2024</option><option value="2025">2025</option><option value="2026">2026</option>
                        <option value="2027">2027</option><option value="2028">2028</option>
                    </select>
                </div>
            </div>

            <div id="taskListContainer" class="space-y-6"></div>
        </div>

        <div class="space-y-6">
            <div class="bg-white rounded-[1.5rem] p-6 shadow-lg border border-slate-100 card-shadow sticky top-6">
                <div class="flex flex-col gap-3 mb-6">
                    <h3 class="font-black text-slate-700 text-lg flex items-center justify-between">
                        <span><i class="fa-solid fa-chart-column accent-text mr-2"></i> Báo cáo tuần</span>
                    </h3>
                    <div class="flex items-center gap-2 bg-slate-50 p-2 rounded-xl border border-slate-200">
                        <i class="fa-regular fa-calendar ml-2 text-slate-400"></i>
                        <input type="date" id="reportDateFilter" onchange="tkRenderReport()" class="bg-transparent border-none outline-none text-sm font-bold text-slate-600 w-full cursor-pointer">
                    </div>
                    <p class="text-xs font-bold text-slate-400" id="reportWeekLabel"></p>
                </div>

                <div class="grid grid-cols-2 gap-3 mb-6" id="tkReportStats"></div>
                
                <div class="mt-4">
                    <div class="flex justify-between items-end h-32 gap-1 border-b border-slate-200 pb-2" id="barChartContainer">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function(){
    const STORE_KEY = 'bd_tasks_v5'; 
    function load(){ try{ return JSON.parse(localStorage.getItem(STORE_KEY))||[]; }catch(e){ return []; } }
    function save(arr){ localStorage.setItem(STORE_KEY, JSON.stringify(arr)); }
    
    let tasks = load();
    let currentFilter = 'all';
    let addMode = 'today';

    function uid(){ return Date.now().toString(36)+Math.random().toString(36).slice(2,6); }
    function formatDate(dateStr) { const [y, m, d] = dateStr.split('-'); return `${d}/${m}/${y}`; }
    function escHtml(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    
    const dNow = new Date();
    const todayStr = `${dNow.getFullYear()}-${String(dNow.getMonth()+1).padStart(2,'0')}-${String(dNow.getDate()).padStart(2,'0')}`;
    
    document.getElementById('todayHeaderLabel').textContent = dNow.toLocaleDateString('vi-VN',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
    document.getElementById('tkDate').value = todayStr;
    document.getElementById('reportDateFilter').value = todayStr;

    const tabBtns = document.querySelectorAll('.add-tab-btn');
    const weekPicker = document.getElementById('weeklyDatePicker');
    const dateInput = document.getElementById('tkDate');
    const weekRefDateInput = document.getElementById('weekRefDate');

    tabBtns.forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            tabBtns.forEach(b => {
                b.classList.remove('active', 'border-[var(--accent)]', 'accent-text');
                b.classList.add('border-transparent', 'text-slate-400');
            });
            this.classList.add('active', 'border-[var(--accent)]', 'accent-text');
            this.classList.remove('border-transparent', 'text-slate-400');
            
            addMode = this.dataset.mode;
            if(addMode === 'today') {
                weekPicker.classList.add('hidden');
                dateInput.value = todayStr;
            } else {
                weekPicker.classList.remove('hidden');
                weekRefDateInput.value = dateInput.value || todayStr;
                renderWeekDays(dateInput.value || todayStr);
            }
        });
    });

    window.renderWeekDays = function(refDateStr) {
        const container = document.getElementById('weekDaysContainer');
        container.innerHTML = '';
        
        let curr = refDateStr ? new Date(refDateStr) : new Date();
        let first = curr.getDate() - curr.getDay() + (curr.getDay() === 0 ? -6 : 1);
        let monday = new Date(curr.setDate(first));

        const dayNames = ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'];
        
        for(let i=0; i<7; i++) {
            let d = new Date(monday);
            d.setDate(monday.getDate() + i);
            let dStr = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
            let dDisplay = `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}`;
            
            let btn = document.createElement('button');
            btn.type = 'button';
            btn.className = `day-btn ${dStr === dateInput.value ? 'active' : ''}`;
            btn.innerHTML = `<div class="font-bold text-[10px] uppercase">${dayNames[i]}</div><div class="font-black text-sm">${dDisplay}</div>`;
            
            btn.onclick = function() {
                document.querySelectorAll('.day-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                dateInput.value = dStr;
            };
            container.appendChild(btn);
        }
    };

    window.tkSaveTask = function(e) {
        e.preventDefault();
        const editId = document.getElementById('tkEditId').value;
        const name = document.getElementById('tkName').value.trim();
        const date = document.getElementById('tkDate').value;
        const pri = document.getElementById('tkPri').value;

        if(!name) return;

        if(editId) {
            let tk = tasks.find(t => t.id === editId);
            if (tk) { tk.name = name; tk.deadline = date; tk.pri = pri; }
            tkCancelEdit();
        } else {
            tasks.push({
                id: uid(), name: name, deadline: date, pri: pri, status: 'todo', createdAt: new Date().toISOString()
            });
            document.getElementById('tkName').value = '';
        }

        save(tasks);
        tkRender(); tkRenderReport();
    };

    window.tkEditTask = function(id) {
        let tk = tasks.find(t => t.id === id);
        if (!tk) return;

        document.getElementById('tkEditId').value = tk.id;
        document.getElementById('tkName').value = tk.name;
        document.getElementById('tkDate').value = tk.deadline;
        document.getElementById('tkPri').value = tk.pri || 'med';
        
        document.getElementById('submitTaskBtn').innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Cập nhật';
        document.getElementById('cancelEditBtn').classList.remove('hidden');
        document.getElementById('editModeBadge').classList.remove('hidden');
        document.getElementById('taskFormContainer').classList.add('border-amber-200');

        document.querySelector('[data-mode="week"]').click();
        document.getElementById('weekRefDate').value = tk.deadline;
        renderWeekDays(tk.deadline);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    };

    window.tkCancelEdit = function() {
        document.getElementById('tkEditId').value = '';
        document.getElementById('tkName').value = '';
        document.getElementById('tkDate').value = todayStr;
        document.getElementById('tkPri').value = 'med';
        
        document.getElementById('submitTaskBtn').innerHTML = '<i class="fa-solid fa-plus"></i> Thêm';
        document.getElementById('cancelEditBtn').classList.add('hidden');
        document.getElementById('editModeBadge').classList.add('hidden');
        document.getElementById('taskFormContainer').classList.remove('border-amber-200');
        
        document.querySelector('[data-mode="today"]').click();
    };

    window.tkToggleStatus = function(id, isChecked) {
        let tk = tasks.find(t => t.id === id);
        if(tk) {
            tk.status = isChecked ? 'done' : 'todo';
            tk.completedAt = isChecked ? new Date().toISOString() : null;
            save(tasks); tkRender(); tkRenderReport();
        }
    };

    window.tkDeleteTask = function(id) {
        if(confirm('Bạn có chắc muốn xóa công việc này?')) {
            tasks = tasks.filter(t => t.id !== id);
            save(tasks); tkRender(); tkRenderReport();
        }
    };

    window.tkRender = function() {
        const filterM = document.getElementById('filterMonth').value;
        const filterY = document.getElementById('filterYear').value;
        let visible = tasks;

        if(filterM || filterY) {
            visible = visible.filter(t => {
                if(!t.deadline) return false;
                const d = new Date(t.deadline);
                const mMatch = filterM ? (d.getMonth() + 1 == filterM) : true;
                const yMatch = filterY ? (d.getFullYear() == filterY) : true;
                return mMatch && yMatch;
            });
        }

        if (currentFilter === 'today') {
            visible = visible.filter(t => t.deadline === todayStr);
        } else if (currentFilter === 'week') {
            let curr = new Date();
            let first = curr.getDate() - curr.getDay() + (curr.getDay() === 0 ? -6 : 1);
            let monday = new Date(curr.setDate(first)); monday.setHours(0,0,0,0);
            let sunday = new Date(monday); sunday.setDate(monday.getDate() + 6); sunday.setHours(23,59,59,999);
            visible = visible.filter(t => { const d = new Date(t.deadline); return d >= monday && d <= sunday; });
        } else if (currentFilter === 'done') {
            visible = visible.filter(t => t.status === 'done');
        } else if (currentFilter === 'overdue') {
            visible = visible.filter(t => t.status !== 'done' && t.deadline < todayStr);
        }

        let overdue = [], today = [], upcoming = [], done = [];
        visible.sort((a,b) => new Date(a.deadline) - new Date(b.deadline));

        visible.forEach(t => {
            if (t.status === 'done') done.push(t);
            else if (t.deadline < todayStr) overdue.push(t);
            else if (t.deadline === todayStr) today.push(t);
            else upcoming.push(t);
        });

        const container = document.getElementById('taskListContainer');
        container.innerHTML = '';

        const renderBlock = (title, icon, colorClass, items) => {
            if(items.length === 0) return '';
            let html = `<div class="mb-6">
                <h4 class="font-black text-sm mb-3 uppercase tracking-wider flex items-center gap-2 ${colorClass}">
                    ${icon} ${title} <span class="bg-slate-100 text-slate-500 px-2 py-0.5 rounded-md text-[10px]">${items.length}</span>
                </h4><div class="flex flex-col gap-3">`;
            
            items.forEach(tk => {
                const isDone = tk.status === 'done';
                const priLabel = tk.pri === 'high' ? '🔴 Mục tiêu' : (tk.pri === 'med' ? '🟡 Thường' : '🟢 Rảnh');
                const lineThrough = isDone ? 'line-through text-slate-400' : 'text-slate-700';
                
                html += `
                <div class="task-item-card pri-${tk.pri} p-4 rounded-2xl border border-slate-100 flex items-start gap-4 shadow-sm">
                    <input type="checkbox" class="task-checkbox mt-0.5" ${isDone ? 'checked' : ''} onchange="tkToggleStatus('${tk.id}', this.checked)">
                    <div class="flex-1">
                        <div class="font-bold text-[15px] ${lineThrough}">${escHtml(tk.name)}</div>
                        <div class="flex gap-3 text-[11px] font-bold text-slate-400 mt-2">
                            <span>${priLabel}</span>
                            <span>📅 ${formatDate(tk.deadline)}</span>
                        </div>
                    </div>
                    <div class="flex gap-1 flex-shrink-0">
                        <button onclick="tkEditTask('${tk.id}')" class="text-slate-400 hover:text-accent hover:bg-slate-100 w-8 h-8 rounded-lg flex items-center justify-center transition">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button onclick="tkDeleteTask('${tk.id}')" class="text-slate-400 hover:text-rose-500 hover:bg-rose-50 w-8 h-8 rounded-lg flex items-center justify-center transition">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>`;
            });
            html += `</div></div>`;
            return html;
        };

        if(visible.length === 0) {
            container.innerHTML = `<div class="text-center py-12 bg-white rounded-[1.5rem] border border-dashed border-slate-200 card-shadow">
                <div class="text-5xl mb-4 opacity-50">🍃</div>
                <h3 class="text-lg font-bold text-slate-500">Không có gì ở đây!</h3>
                <p class="text-slate-400 text-sm mt-1">Chưa có công việc cho hôm nay.</p>
            </div>`;
            return;
        }

        container.innerHTML += renderBlock('Quá hạn', '🚨', 'text-rose-500', overdue);
        container.innerHTML += renderBlock('Hôm nay', '☀️', 'accent-text', today);
        container.innerHTML += renderBlock('Sắp tới', '📅', 'text-slate-600', upcoming);
        container.innerHTML += renderBlock('Đã hoàn thành', '✅', 'text-emerald-500', done);
    };

    window.tkRenderReport = function() {
        const dateVal = document.getElementById('reportDateFilter').value;
        if(!dateVal) return;
        
        let target = new Date(dateVal);
        let day = target.getDay();
        let diff = target.getDate() - day + (day === 0 ? -6 : 1);
        let monday = new Date(target.setDate(diff)); monday.setHours(0,0,0,0);
        let sunday = new Date(monday); sunday.setDate(monday.getDate() + 6); sunday.setHours(23,59,59,999);

        let wMonth = monday.getMonth() + 1;
        let wYear = monday.getFullYear();
        let fDay = new Date(wYear, wMonth - 1, 1).getDay();
        let wNum = Math.ceil((monday.getDate() + (fDay === 0 ? 6 : fDay - 1)) / 7);
        document.getElementById('reportWeekLabel').textContent = `Tuần ${wNum} Tháng ${wMonth}, ${wYear}`;

        const wTasks = tasks.filter(t => {
            const d = new Date(t.deadline);
            return d >= monday && d <= sunday;
        });

        const doneT = wTasks.filter(t => t.status === 'done').length;
        document.getElementById('tkReportStats').innerHTML = `
            <div class="bg-slate-50 p-4 rounded-xl border border-slate-100 text-center">
                <div class="text-3xl font-black text-slate-700">${wTasks.length}</div>
                <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mt-1">Tổng việc</div>
            </div>
            <div class="bg-emerald-50 p-4 rounded-xl border border-emerald-100 text-center">
                <div class="text-3xl font-black text-emerald-500">${doneT}</div>
                <div class="text-[10px] font-bold text-emerald-600/70 uppercase tracking-wide mt-1">Đã xong</div>
            </div>
        `;

        let chartData = [];
        let maxCount = 1; 
        const dayNames = ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'];
        
        for(let i=0; i<7; i++) {
            let d = new Date(monday); d.setDate(monday.getDate() + i);
            let dStr = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
            
            let count = tasks.filter(t => t.deadline === dStr && t.status === 'done').length;
            if(count > maxCount) maxCount = count;
            chartData.push({ lbl: dayNames[i], cnt: count, isToday: dStr === todayStr });
        }

        const chartContainer = document.getElementById('barChartContainer');
        chartContainer.innerHTML = '';
        
        chartData.forEach(item => {
            let heightPct = Math.round((item.cnt / maxCount) * 100);
            let barClass = item.isToday ? 'is-today' : 'not-today';
            let labelClass = item.isToday ? 'active-lbl' : '';
            
            chartContainer.innerHTML += `
            <div class="chart-col">
                <span class="text-[10px] font-bold text-slate-500">${item.cnt > 0 ? item.cnt : ''}</span>
                <div class="chart-bar ${barClass}" style="height: ${heightPct}%;"></div>
                <span class="chart-label ${labelClass}">${item.lbl}</span>
            </div>`;
        });
    };

    document.querySelectorAll('.filter-pill').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            currentFilter = this.dataset.filter;
            document.getElementById('filterMonth').value = '';
            document.getElementById('filterYear').value = '';
            tkRender();
        });
    });

    tkRender();
    tkRenderReport();
})();
</script>