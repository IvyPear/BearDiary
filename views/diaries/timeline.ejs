<%
  title = 'Nhật ký - Moodiary';
  let entries = [
    { 
      date: 'Sun, April 5, 2026', 
      mood: 'Happy', 
      moodIcon: '😊', 
      moodColor: 'yellow',
      content: 'Started the day with a perfect cup of coffee. The morning light was golden and everything felt just right...',
      image: 'https://images.unsplash.com/photo-1517842645767-c639042777db?w=500',
      isStarred: true,
      side: 'left'
    },
    { 
      date: 'Sat, April 4, 2026', 
      mood: 'Calm', 
      moodIcon: '😌', 
      moodColor: 'emerald',
      content: 'Watched the sunset from my balcony today. The sky was painted with beautiful orange and pink hues. It reminded me to slow down and appreciate the little moments.',
      image: 'https://images.unsplash.com/photo-1501854140801-50d01698950b?w=500',
      isStarred: false,
      side: 'right'
    },
    { 
      date: 'Fri, April 3, 2026', 
      mood: 'Sad', 
      moodIcon: '😢', 
      moodColor: 'rose',
      content: 'Today was a bit tough. Felt overwhelmed with work and personal stuff. But writing this down helps me process my thoughts.',
      image: null,
      isStarred: false,
      side: 'left'
    },
    { 
      date: 'Thu, April 2, 2026', 
      mood: 'Excited', 
      moodIcon: '🥳', 
      moodColor: 'purple',
      content: 'Got a promotion at work today! All the hard work finally paid off. Celebrated with close friends in the evening.',
      image: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=500',
      isStarred: true,
      side: 'right'
    },
    { 
      date: 'Wed, April 1, 2026', 
      mood: 'Grateful', 
      moodIcon: '🙏', 
      moodColor: 'blue',
      content: 'So grateful for my family and friends. Had a wonderful dinner with everyone and shared lots of laughter.',
      image: null,
      isStarred: false,
      side: 'left'
    }
  ];
%>

<style>
  .timeline-container { position: relative; }
  .timeline-line {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 100%;
    background-color: #DBEAFE;
    z-index: 0;
  }

  .timeline-card {
    width: 45%;
    background: white;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(0,0,0,0.04);
    border: 1px solid var(--card-border);
    z-index: 10;
  }

  .emoji-dot {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 36px;
    height: 36px;
    background: white;
    border: 2px solid var(--accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    z-index: 20;
  }

  .filter-pill {
    background: white;
    border: 1px solid #E2E8F0;
    padding: 6px 16px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    color: #64748B;
    transition: all 0.2s;
    white-space: nowrap;
    cursor: pointer;
  }
  .filter-pill.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }
  .filter-pill:hover {
    background: var(--accent-light);
    border-color: var(--accent);
  }

  .filter-select {
    padding: 10px 16px;
    border-radius: 999px;
    border: 1px solid #E0ECF9;
    background: white;
    font-size: 14px;
    font-weight: 600;
    color: #2C4A7C;
    min-width: 140px;
    cursor: pointer;
  }

  [data-theme="dark"] .timeline-card { background: #1E2937; border-color: #334155; }
  [data-theme="dark"] .filter-pill, [data-theme="dark"] .filter-select { background: #1E2937; border-color: #334155; color: #E2E8F0; }
  [data-theme="dark"] .timeline-line { background-color: #334155; }
  [data-theme="dark"] .emoji-dot { background: #1E2937; border-color: #475569; }
</style>

<div class="mb-8 flex items-center justify-between">
  <div class="flex items-center gap-4">
    <div class="w-12 h-12 bg-[#5A9BD4] rounded-2xl flex items-center justify-center text-white text-2xl shadow-lg">📖</div>
    <div>
      <h2 class="text-3xl font-black text-[#2C4A7C]">Dòng thời gian</h2>
      <p class="text-slate-400 font-bold text-sm">Tất cả nhật ký của bạn trong một nơi</p>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <select id="monthFilter" class="filter-select">
      <option value="">Tất cả tháng</option>
      <option value="1">Tháng 1</option>
      <option value="2">Tháng 2</option>
      <option value="3">Tháng 3</option>
      <option value="4" selected>Tháng 4</option>
      <option value="5">Tháng 5</option>
      <option value="6">Tháng 6</option>
      <option value="7">Tháng 7</option>
      <option value="8">Tháng 8</option>
      <option value="9">Tháng 9</option>
      <option value="10">Tháng 10</option>
      <option value="11">Tháng 11</option>
      <option value="12">Tháng 12</option>
    </select>
    <select id="yearFilter" class="filter-select">
      <option value="2024">2024</option>
      <option value="2025">2025</option>
      <option value="2026" selected>2026</option>
      <option value="2027">2027</option>
    </select>
  </div>
</div>

<div class="flex flex-wrap gap-2 mb-12" id="filterPills">
  <button class="filter-pill active" data-mood="all">Tất cả (<%= entries.length %>)</button>
  <button class="filter-pill" data-mood="happy">😊 Happy (2)</button>
  <button class="filter-pill" data-mood="calm">😌 Calm (1)</button>
  <button class="filter-pill" data-mood="excited">🥳 Excited (1)</button>
  <button class="filter-pill" data-mood="grateful">🙏 Grateful (1)</button>
  <button class="filter-pill" data-mood="sad">😢 Sad (1)</button>
</div>

<div class="relative">
  <div class="flex items-center gap-4 mb-12">
    <span class="bg-[#E0ECF9] text-[#5A9BD4] px-6 py-2 rounded-full font-black text-sm">Tháng 4, 2026</span>
    <div class="h-[1px] flex-1 bg-slate-100"></div>
    <span class="text-xs font-bold text-slate-300 uppercase" id="entryCount"><%= entries.length %> bài viết</span>
  </div>

  <div class="timeline-container space-y-20 pb-20" id="timelineContainer">
    <div class="timeline-line"></div>
    
    <% entries.forEach((entry, index) => { %>
      <div class="flex <%= entry.side === 'left' ? 'justify-start' : 'justify-end' %> relative timeline-item" 
           data-mood="<%= entry.mood.toLowerCase() %>"
           data-date="<%= entry.date %>">
        <div class="emoji-dot border-<%= entry.moodColor %>-200"><%= entry.moodIcon %></div>
        <div class="timeline-card bg-<%= entry.moodColor %>-50/50 border border-<%= entry.moodColor %>-100">
          <% if (entry.image) { %>
            <img src="<%= entry.image %>" class="h-48 w-full object-cover" />
          <% } %>
          <div class="p-6">
            <div class="flex justify-between items-center mb-4">
              <span class="bg-white px-3 py-1 rounded-full text-[10px] font-bold text-<%= entry.moodColor %>-600">
                <%= entry.moodIcon %> <%= entry.mood %>
              </span>
              <div class="flex gap-3 text-slate-400">
                <i onclick="editEntry(this)" class="fa-solid fa-pen hover:text-[#5A9BD4] cursor-pointer"></i>
                <i class="fa-<%= entry.isStarred ? 'solid' : 'regular' %> fa-star hover:text-yellow-400 cursor-pointer"></i>
                <i onclick="deleteEntry(this)" class="fa-solid fa-trash-can hover:text-rose-500 cursor-pointer"></i>
              </div>
            </div>
            <p class="text-[10px] font-black text-slate-400 uppercase mb-2">📅 <%= entry.date %></p>
            <p class="text-sm font-bold text-slate-600 leading-relaxed">
              <%= entry.content %>
            </p>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<script>
  function editEntry(element) {
    alert("🖊️ Chỉnh sửa bài viết...");
  }

  function deleteEntry(element) {
    if (confirm("Bạn có chắc muốn xóa bài viết này?")) {
      alert("🗑️ Đã xóa bài viết!");
    }
  }

  // Filter functionality
  const filterPills = document.querySelectorAll('.filter-pill');
  const timelineItems = document.querySelectorAll('.timeline-item');
  const entryCountSpan = document.getElementById('entryCount');

  filterPills.forEach(pill => {
    pill.addEventListener('click', function() {
      // Remove active class from all pills
      filterPills.forEach(p => p.classList.remove('active'));
      this.classList.add('active');
      
      const mood = this.getAttribute('data-mood');
      let visibleCount = 0;
      
      timelineItems.forEach(item => {
        if (mood === 'all' || item.getAttribute('data-mood') === mood) {
          item.style.display = 'flex';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });
      
      entryCountSpan.innerText = visibleCount + ' bài viết';
    });
  });

  // Month and Year filter (demo)
  document.getElementById('monthFilter').addEventListener('change', function() {
    alert('Lọc theo tháng: ' + this.options[this.selectedIndex].text);
  });
  
  document.getElementById('yearFilter').addEventListener('change', function() {
    alert('Lọc theo năm: ' + this.value);
  });
</script>