<!DOCTYPE html>
<html lang="vi" data-theme="blue">

<head>
  <script>
    (function(){
      try {
        var isDark = localStorage.getItem('moodiary-is-dark') === '1';
        var saved = localStorage.getItem('moodiary-theme') || 'blue';
        var accent = localStorage.getItem('moodiary-accent');
        if (isDark) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', saved);
        }
        if (accent) {
          document.documentElement.style.setProperty('--accent', accent);
        }
      } catch (e) { /* ignore */ }
    })();
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
  <title><%= typeof title != 'undefined' ? title : 'Bear Diary' %></title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg-main: #F8FAFF;
      --primary-dark: #2C4A7C;
      --accent: #5A9BD4;
      --accent-light: #A3C4E8;
      --accent-dark: #3B82F6;
      --muted: #64748B;
      --danger: #ef4444;
      --card-bg: white;
      --card-border: #E0ECF9;
      --accent-rgb: 90, 155, 212;
    }

    [data-theme="blue"] {
      --accent: #5A9BD4;
      --accent-light: #A3C4E8;
      --accent-dark: #3B82F6;
      --bg-main: #F8FAFF;
      --primary-dark: #2C4A7C;
      --card-border: #E0ECF9;
      --accent-rgb: 90, 155, 212;
    }

    [data-theme="pink"] {
      --accent: #F472B6;
      --accent-light: #FBCFE8;
      --accent-dark: #EC4899;
      --bg-main: #FFF5F8;
      --primary-dark: #831843;
      --card-border: #FCE7F3;
      --accent-rgb: 244, 114, 182;
    }

    [data-theme="green"] {
      --accent: #34D399;
      --accent-light: #A7F3D0;
      --accent-dark: #10B981;
      --bg-main: #F0FDF4;
      --primary-dark: #064E3B;
      --card-border: #D1FAE5;
      --accent-rgb: 52, 211, 153;
    }

    [data-theme="purple"] {
      --accent: #A78BFA;
      --accent-light: #DDD6FE;
      --accent-dark: #8B5CF6;
      --bg-main: #F5F3FF;
      --primary-dark: #4C1D95;
      --card-border: #EDE9FE;
      --accent-rgb: 167, 139, 250;
    }

    [data-theme="yellow"] {
      --accent: #FBBF24;
      --accent-light: #FDE68A;
      --accent-dark: #F59E0B;
      --bg-main: #FEFCE8;
      --primary-dark: #854D0E;
      --card-border: #FEF08A;
      --accent-rgb: 251, 191, 36;
    }

    [data-theme="dark"] {
      --bg-main: #0F172A;
      --primary-dark: #F1F5F9;
      --card-border: #334155;
      --muted: #94A3B8;
      --card-bg: #1E293B;
      --accent: #5A9BD4;
      --accent-light: #3B82F6;
      --accent-dark: #60A5FA;
      --accent-rgb: 90, 155, 212;
    }

    body {
      font-family: 'Nunito', sans-serif;
      background-color: var(--bg-main);
      color: var(--primary-dark);
      transition: all 0.3s ease;
    }

    html, body { overflow-x: hidden; }
    main { min-width: 0; }
    main > * { max-width: 1100px; margin: 0 auto; box-sizing: border-box; }

    .primary-text { color: var(--primary-dark); }
    .btn-accent:hover { background: var(--primary-dark) !important; }
    .accent-bg { background: var(--accent); color: white; }
    .accent-text { color: var(--accent); }
    .accent-border { border-color: var(--accent) !important; }
    .hover-accent:hover { color: var(--accent) !important; }

    /* Sidebar - always visible on desktop, collapsible on mobile */
    aside {
      position: fixed;
      left: 0;
      top: 0;
      bottom: 0;
      width: 260px;
      background-color: white;
      border-right: 1px solid var(--card-border);
      display: flex;
      flex-direction: column;
      padding: 1.5rem;
      transition: transform 0.3s ease;
      z-index: 80;
    }

    [data-theme="dark"] aside {
      background-color: #1E2937;
      border-right-color: #334155;
    }

    /* Main content with margin for sidebar */
    main {
      margin-left: 260px;
      padding: 2rem;
      transition: margin 0.3s ease;
    }

    /* Mobile styles */
    @media (max-width: 768px) {
      aside {
        transform: translateX(-100%);
        width: 240px;
      }
      
      body.sidebar-open aside {
        transform: translateX(0);
        box-shadow: 0 0 20px rgba(0,0,0,0.3);
      }
      
      main {
        margin-left: 0;
        padding: 1rem;
        padding-top: 70px;
      }
      
      .mobile-top {
        display: flex;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 56px;
        background: var(--card-bg);
        border-bottom: 1px solid var(--card-border);
        z-index: 70;
        padding: 0 1rem;
        align-items: center;
        gap: 1rem;
      }
      
      .mobile-menu-btn {
        background: none;
        border: none;
        font-size: 24px;
        color: var(--primary-dark);
        cursor: pointer;
        padding: 8px;
      }
    }
    
    @media (min-width: 769px) {
      .mobile-top {
        display: none !important;
      }
    }

    /* Navigation items - FIXED */
    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 16px;
      font-weight: 700;
      transition: all 0.3s ease;
      color: #94A3B8;
      position: relative;
      overflow: hidden;
      cursor: pointer;
      text-decoration: none;
      background: transparent;
    }

    .nav-item i { 
      width: 20px; 
      transition: all 0.3s ease; 
      color: #94A3B8;
    }
    
    .nav-item:hover {
      background: rgba(var(--accent-rgb), 0.1);
      color: var(--accent);
      transform: translateX(4px);
    }
    
    .nav-item:hover i { 
      color: var(--accent);
      transform: scale(1.1); 
    }
    
    /* Active state - QUAN TRỌNG: phải override các style khác */
    .nav-item.active {
      background: var(--accent) !important;
      color: white !important;
      box-shadow: 0 8px 25px rgba(var(--accent-rgb), 0.35);
    }
    
    .nav-item.active i { 
      color: white !important; 
    }
    
    .nav-item.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 4px;
      height: 60%;
      background: white;
      border-radius: 0 4px 4px 0;
    }
    
    [data-theme="dark"] .nav-item {
      color: #94A3B8;
    }
    
    [data-theme="dark"] .nav-item:hover {
      background: rgba(var(--accent-rgb), 0.15);
      color: var(--accent);
    }
    
    [data-theme="dark"] .nav-item.active {
      background: var(--accent) !important;
      color: white !important;
    }
    
    [data-theme="dark"] .nav-item.active::before {
      background: white;
    }

    /* Logout button specific */
    .nav-item.logout-item {
      color: #f43f5e;
    }
    
    .nav-item.logout-item:hover {
      background: rgba(244, 63, 94, 0.1);
      color: #f43f5e;
    }
    
    .nav-item.logout-item i {
      color: #f43f5e;
    }
    
    .nav-item.logout-item:hover i {
      color: #f43f5e;
    }

    .app-logo {
      width: 52px;
      height: 52px;
      background: linear-gradient(135deg, var(--accent), var(--accent-light));
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      color: white;
      box-shadow: 0 6px 20px rgba(var(--accent-rgb), 0.35);
      transition: transform 0.3s ease;
    }
    .app-logo:hover { transform: scale(1.05); }

    .card-shadow {
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
      border: 1px solid var(--card-border);
      background: var(--card-bg);
    }

    .banner-gradient {
      background: linear-gradient(135deg, var(--accent), var(--accent-light));
    }

    .mood-btn {
      transition: all 0.25s;
      border: 1px solid var(--card-border);
      background: var(--card-bg);
    }
    .mood-btn:hover {
      border-color: var(--accent);
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(var(--accent-rgb), 0.25);
    }

    .bear-float { animation: float 3.5s ease-in-out infinite; }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    .theme-switch {
      position: relative;
      display: inline-block;
      width: 44px;
      height: 24px;
    }
    .theme-switch input { opacity: 0; width: 0; height: 0; }
    .slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: #cbd5e1;
      transition: 0.3s;
      border-radius: 34px;
    }
    .slider:before {
      position: absolute;
      content: "";
      height: 18px;
      width: 18px;
      left: 3px;
      bottom: 3px;
      background-color: white;
      transition: 0.3s;
      border-radius: 50%;
    }
    input:checked+.slider { background-color: var(--accent); }
    input:checked+.slider:before { transform: translateX(20px); }

    /* Dark mode specific overrides */
    [data-theme="dark"] .card-shadow {
      background: #1E293B;
    }
    
    [data-theme="dark"] textarea,
    [data-theme="dark"] input,
    [data-theme="dark"] select {
      background: #0F172A;
      color: #E2E8F0;
      border-color: #334155;
    }
    
    [data-theme="dark"] .banner-gradient {
      background: linear-gradient(135deg, var(--accent), #0F172A);
    }
    
    [data-theme="dark"] .text-slate-400 { color: #94A3B8 !important; }
    [data-theme="dark"] .text-slate-700 { color: #E2E8F0 !important; }
    [data-theme="dark"] .text-slate-500,
    [data-theme="dark"] .text-slate-600 { color: #CBD5E1 !important; }
  </style>
</head>

<body>

  <!-- Mobile top bar -->
  <div class="mobile-top">
    <button class="mobile-menu-btn" id="mobileMenuBtn">
      <i class="fa-solid fa-bars"></i>
    </button>
    <div class="app-logo" style="width: 40px; height: 40px; font-size: 24px;">🐻</div>
    <div style="flex:1"></div>
    <div class="text-sm font-bold accent-text">Bear Diary</div>
  </div>

  <!-- Sidebar -->
  <aside>
    <div class="flex items-center gap-3 mb-10">
      <div class="app-logo">🐻</div>
      <div>
        <h1 class="font-bold text-2xl leading-none primary-text">Bear Diary</h1>
        <p class="text-[10px] accent-text font-bold uppercase tracking-[1px]">YOUR DAILY JOURNAL</p>
      </div>
    </div>

    <nav class="flex-1 space-y-2">
      <a href="/" class="nav-item <%= title === 'Trang chủ - Bear Diary' ? 'active' : '' %>">
        <i class="fa-solid fa-house"></i>
        <span>Trang chủ</span>
      </a>
      <a href="/diaries/timeline" class="nav-item <%= title === 'Dòng thời gian - Bear Diary' || title === 'Nhật ký - Bear Diary' ? 'active' : '' %>">
        <i class="fa-solid fa-book-open"></i>
        <span>Timeline</span>
      </a>
      <a href="/diaries/report" class="nav-item <%= title === 'Mood Report - Bear Diary' || title === 'Báo cáo - Bear Diary' ? 'active' : '' %>">
        <i class="fa-solid fa-chart-simple"></i>
        <span>Báo cáo</span>
      </a>
      <a href="/diaries/tasks" class="nav-item <%= title === 'Công việc - Bear Diary' ? 'active' : '' %>">
        <i class="fa-solid fa-list-check"></i>
        <span>Công việc</span>
      </a>
      <a href="/diaries/profile" class="nav-item <%= title === 'Cá nhân - Bear Diary' ? 'active' : '' %>">
        <i class="fa-solid fa-user"></i>
        <span>Cá nhân</span>
      </a>
    </nav>

    <div class="mt-auto space-y-4">
      <div class="flex items-center justify-between px-4 py-3">
        <div class="flex items-center gap-4 font-bold text-slate-400">
          <i class="fa-solid fa-moon"></i> <span class="dark-mode-text">Chế độ tối</span>
        </div>
        <label class="theme-switch">
          <input type="checkbox" id="darkToggle">
          <span class="slider"></span>
        </label>
      </div>
      <a href="/auth/logout" class="nav-item logout-item">
        <i class="fa-solid fa-arrow-right-from-bracket"></i>
        <span>Đăng xuất</span>
      </a>
      <div class="flex justify-center pt-4">
        <div class="w-16 h-16 bg-[#E0ECF9] rounded-2xl flex items-center justify-center text-4xl bear-float">🐻</div>
      </div>
    </div>
  </aside>

  <main>
    <%- body %>
  </main>

  <script>
    // Date display
    const dateOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
    const dateEl = document.getElementById('currentDate');
    if (dateEl) {
      dateEl.innerText = new Date().toLocaleDateString('vi-VN', dateOptions);
    }

    const THEME_ACCENTS = {
      blue: '#5A9BD4',
      pink: '#F472B6',
      green: '#34D399',
      purple: '#A78BFA',
      yellow: '#FBBF24'
    };
    window.THEME_ACCENTS = THEME_ACCENTS;

    function setTheme(theme) {
      if (theme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', theme);
      }
      if (theme !== 'dark') {
        localStorage.setItem('moodiary-theme', theme);
        const accent = THEME_ACCENTS[theme] || THEME_ACCENTS['blue'];
        localStorage.setItem('moodiary-accent', accent);
        document.documentElement.style.setProperty('--accent', accent);
        // Update RGB values
        const rgbMap = {
          blue: '90, 155, 212',
          pink: '244, 114, 182',
          green: '52, 211, 153',
          purple: '167, 139, 250',
          yellow: '251, 191, 36'
        };
        document.documentElement.style.setProperty('--accent-rgb', rgbMap[theme] || '90, 155, 212');
        localStorage.setItem('moodiary-is-dark', '0');
      } else {
        const storedAccent = localStorage.getItem('moodiary-accent') || THEME_ACCENTS['blue'];
        document.documentElement.style.setProperty('--accent', storedAccent);
        document.documentElement.style.setProperty('--accent-rgb', '90, 155, 212');
        localStorage.setItem('moodiary-is-dark', '1');
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      const savedTheme = localStorage.getItem('moodiary-theme') || 'blue';
      const isDark = localStorage.getItem('moodiary-is-dark') === '1';
      if (isDark) {
        setTheme('dark');
      } else {
        setTheme(savedTheme);
      }

      const toggle = document.getElementById('darkToggle');
      if (toggle) {
        toggle.checked = isDark;
        toggle.addEventListener('change', function () {
          const current = document.documentElement.getAttribute('data-theme');
          if (toggle.checked) {
            if (current && current !== 'dark') localStorage.setItem('moodiary-previous-theme', current);
            setTheme('dark');
            localStorage.setItem('moodiary-is-dark', '1');
          } else {
            const prev = localStorage.getItem('moodiary-previous-theme') || localStorage.getItem('moodiary-theme') || 'blue';
            setTheme(prev);
            localStorage.setItem('moodiary-is-dark', '0');
          }
        });
      }

      // Mobile menu
      const mobileBtn = document.getElementById('mobileMenuBtn');
      if (mobileBtn) {
        mobileBtn.addEventListener('click', function () {
          document.body.classList.toggle('sidebar-open');
        });
      }

      // Close sidebar when clicking on overlay (main content)
      const mainEl = document.querySelector('main');
      if (mainEl) {
        mainEl.addEventListener('click', function () {
          if (window.innerWidth <= 768 && document.body.classList.contains('sidebar-open')) {
            document.body.classList.remove('sidebar-open');
          }
        });
      }
      
      // Highlight current page in sidebar based on URL
      const currentPath = window.location.pathname;
      const navLinks = document.querySelectorAll('.nav-item');
      navLinks.forEach(link => {
        const href = link.getAttribute('href');
        if (href && currentPath === href) {
          link.classList.add('active');
        } else if (href === '/' && currentPath === '/') {
          link.classList.add('active');
        } else if (href !== '/' && currentPath.startsWith(href) && href !== '/') {
          link.classList.add('active');
        }
      });
    });
  </script>
</body>

</html>