<!DOCTYPE html>
<html lang="vi" data-theme="blue">

<head>
  <script>
    (function () {
      try {
        var isDark = localStorage.getItem('bd-dark-mode') === 'true';
        var theme = localStorage.getItem('moodiary-theme') || 'blue';
        var accent = localStorage.getItem('moodiary-accent') || '#5A9BD4';
        
        if (isDark) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', theme);
        }
        document.documentElement.style.setProperty('--accent', accent);
      } catch (e) { /* ignore */ }
    })();
  </script>
  
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
  <title>
    <%= typeof title != 'undefined' ? title : 'Bear Diary' %>
  </title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <div class="mobile-top">
    <button class="mobile-menu-btn" id="mobileMenuBtn">
      <i class="fa-solid fa-bars"></i>
    </button>
    <div class="app-logo" style="width: 40px; height: 40px; font-size: 24px;">🐻</div>
    <div style="flex:1"></div>
    <div class="text-sm font-bold accent-text">Bear Diary</div>
  </div>

  <aside>
    <div class="flex items-center gap-3 mb-10">
      <div class="app-logo">🐻</div>
      <div>
        <h1 class="font-bold text-2xl leading-none primary-text">Bear Diary</h1>
        <p class="text-[10px] accent-text font-bold uppercase tracking-[1px]">YOUR DAILY JOURNAL</p>
      </div>
    </div>

    <nav class="flex-1 space-y-2">
      <a href="/diaries/home" class="nav-item <%= (typeof title !== 'undefined' && title.includes('Trang chủ')) ? 'active' : '' %>">
        <i class="fa-solid fa-house"></i>
        <span>Trang chủ</span>
      </a>
      <a href="/diaries/timeline" class="nav-item <%= (typeof title !== 'undefined' && (title.includes('Dòng thời gian') || title.includes('Nhật ký'))) ? 'active' : '' %>">
        <i class="fa-solid fa-book-open"></i>
        <span>Timeline</span>
      </a>
      <a href="/diaries/report" class="nav-item <%= (typeof title !== 'undefined' && (title.includes('Báo cáo') || title.includes('Mood Report'))) ? 'active' : '' %>">
        <i class="fa-solid fa-chart-simple"></i>
        <span>Báo cáo</span>
      </a>
      <a href="/diaries/tasks" class="nav-item <%= (typeof title !== 'undefined' && title.includes('Công việc')) ? 'active' : '' %>">
        <i class="fa-solid fa-list-check"></i>
        <span>Công việc</span>
      </a>
      <a href="/diaries/profile" class="nav-item <%= (typeof title !== 'undefined' && (title.includes('Cá nhân') || title.includes('Hồ sơ'))) ? 'active' : '' %>">
        <i class="fa-solid fa-user"></i>
        <span>Cá nhân</span>
      </a>
    </nav>

    <div class="mt-auto space-y-4">
      <div class="flex items-center justify-between px-4 py-3">
        <div class="flex items-center gap-4 font-bold text-slate-400">
          <i class="fa-solid fa-moon"></i> <span class="dark-mode-text">Chế độ tối</span>
        </div>
        <label class="theme-switch">
          <input type="checkbox" id="darkToggle">
          <span class="slider"></span>
        </label>
      </div>
      <a href="/auth/logout" class="nav-item logout-item">
        <i class="fa-solid fa-arrow-right-from-bracket"></i>
        <span>Đăng xuất</span>
      </a>
      <div class="flex justify-center pt-4">
        <div class="w-16 h-16 bg-[#E0ECF9] rounded-2xl flex items-center justify-center text-4xl bear-float">🐻</div>
      </div>
    </div>
  </aside>

  <main>
    <%- body %>
  </main>

  <script>
    const THEME_ACCENTS = {
      blue: '#5A9BD4',
      pink: '#F8B4D9',
      green: '#34D399',
      purple: '#D4B3FF',
      yellow: '#F9D77E'
    };
    window.THEME_ACCENTS = THEME_ACCENTS;

    // HÀM ĐỔI THEME ĐƯỢC TỐI ƯU
    window.setTheme = function(themeName) {
      if (themeName === 'dark') return;

      const accent = THEME_ACCENTS[themeName] || THEME_ACCENTS['blue'];
      localStorage.setItem('moodiary-theme', themeName);
      localStorage.setItem('moodiary-accent', accent);
      
      // Luôn cập nhật màu chủ đạo
      document.documentElement.style.setProperty('--accent', accent);

      // Nếu KHÔNG BẬT dark mode, mới thay đổi data-theme
      if (localStorage.getItem('bd-dark-mode') !== 'true') {
        document.documentElement.setAttribute('data-theme', themeName);
      } else {
        // Đảm bảo vẫn giữ màu tối nếu đang bật
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    };

    // MUTATION OBSERVER: KHÓA CỨNG DARK MODE
    // Tự động chặn các đoạn script cũ trên trang Profile cố tình đè data-theme
    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        if (mutation.attributeName === 'data-theme') {
          const currentTheme = document.documentElement.getAttribute('data-theme');
          const isDark = localStorage.getItem('bd-dark-mode') === 'true';
          
          // Nếu đang ở Dark Mode mà hệ thống cố đổi sang theme khác (blue, pink...), ép nó quay lại dark ngay lập tức
          if (isDark && currentTheme !== 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        }
      });
    });
    observer.observe(document.documentElement, { attributes: true });

    document.addEventListener('DOMContentLoaded', function () {
      const dateEl = document.getElementById('currentDate');
      if (dateEl) {
        dateEl.innerText = new Date().toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      }

      // XỬ LÝ NÚT BẬT/TẮT DARK MODE
      const toggle = document.getElementById('darkToggle');
      if (toggle) {
        toggle.checked = localStorage.getItem('bd-dark-mode') === 'true';
        
        toggle.addEventListener('change', function () {
          if (this.checked) {
            localStorage.setItem('bd-dark-mode', 'true');
            document.documentElement.setAttribute('data-theme', 'dark');
          } else {
            localStorage.setItem('bd-dark-mode', 'false');
            const savedTheme = localStorage.getItem('moodiary-theme') || 'blue';
            document.documentElement.setAttribute('data-theme', savedTheme);
          }
        });
      }

      // MOBILE MENU
      const mobileBtn = document.getElementById('mobileMenuBtn');
      if (mobileBtn) {
        mobileBtn.addEventListener('click', function () {
          document.body.classList.toggle('sidebar-open');
        });
      }
      const mainEl = document.querySelector('main');
      if (mainEl) {
        mainEl.addEventListener('click', function () {
          if (window.innerWidth <= 768 && document.body.classList.contains('sidebar-open')) {
            document.body.classList.remove('sidebar-open');
          }
        });
      }

      // HIỆU ỨNG TÔ SÁNG NAVBAR
      const currentPath = window.location.pathname;
      const navLinks = document.querySelectorAll('.nav-item');
      navLinks.forEach(link => {
        const href = link.getAttribute('href');
        if (href && currentPath === href) {
          link.classList.add('active');
        } else if (href === '/' && currentPath === '/') {
          link.classList.add('active');
        } else if (href !== '/' && currentPath.startsWith(href) && href !== '/') {
          link.classList.add('active');
        }
      });
    });
  </script>
</body>
</html>