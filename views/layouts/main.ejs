<!DOCTYPE html>
<html lang="vi" data-theme="blue">

<head>
  <script>
    // Apply saved theme asap to avoid flash and ensure persistence across views
    (function(){
      try {
        var saved = localStorage.getItem('moodiary-theme') || 'blue';
        if (saved && saved !== 'dark') localStorage.setItem('moodiary-previous-theme', saved);
        document.documentElement.setAttribute('data-theme', saved);
      } catch (e) { /* ignore */ }
    })();
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= typeof title !='undefined' ? title : 'Bear Diary' %>
  </title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg-main: #F8FAFF;
      --primary-dark: #2C4A7C;
      --accent: #5A9BD4;
      --accent-light: #A3C4E8;
      --card-border: #E0ECF9;
    }

    /* Pastel Themes */
    [data-theme="blue"] {
      --accent: #5A9BD4;
      --bg-main: #F8FAFF;
      --primary-dark: #2C4A7C;
      --card-border: #E0ECF9;
    }

    [data-theme="pink"] {
      --accent: #F8B4D9;
      --bg-main: #FFF5F8;
      --primary-dark: #831843;
      --card-border: #FCE7F3;
    }

    [data-theme="green"] {
      --accent: #A8E6CF;
      --bg-main: #F0FDF4;
      --primary-dark: #064E3B;
      --card-border: #D1FAE5;
    }

    [data-theme="purple"] {
      --accent: #D4B3FF;
      --bg-main: #F5F3FF;
      --primary-dark: #4C1D95;
      --card-border: #EDE9FE;
    }

    [data-theme="yellow"] {
      --accent: #F9D77E;
      --bg-main: #FEFCE8;
      --primary-dark: #854D0E;
      --card-border: #FEF08A;
    }

    /* Dark Mode */
    [data-theme="dark"] {
      --accent: #60A5FA;
      --bg-main: #0F172A;
      --primary-dark: #F1F5F9;
      --card-border: #334155;
    }

    body {
      font-family: 'Nunito', sans-serif;
      background-color: var(--bg-main);
      color: var(--primary-dark);
      transition: all 0.3s ease;
    }

    [data-theme="dark"] body {
      background-color: #0F172A;
      color: #F1F5F9;
    }

    [data-theme="dark"] aside {
      background-color: #1E2937;
      border-right-color: #334155;
    }

    [data-theme="dark"] .card-shadow,
    [data-theme="dark"] .mood-btn {
      background: #1E2937;
      border-color: #334155;
    }

    [data-theme="dark"] .text-slate-400 {
      color: #94A3B8 !important;
    }

    [data-theme="dark"] .text-slate-500,
    [data-theme="dark"] .text-slate-600 {
      color: #CBD5E1 !important;
    }

    [data-theme="dark"] textarea {
      background: #0F172A;
      color: #E2E8F0;
      border-color: #334155;
    }

    [data-theme="dark"] .banner-gradient {
      background: linear-gradient(135deg, #1E40AF, #3B82F6);
    }

    [data-theme="dark"] .nav-item.active {
      background: var(--accent);
      color: white !important;
    }

    [data-theme="dark"] .nav-item.active i {
      color: white !important;
    }

    .sidebar-active {
      background: var(--accent);
      color: white !important;
      box-shadow: 0 8px 25px rgba(90, 155, 212, 0.35);
    }

    /* Nav Item Styles */
    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 16px;
      font-weight: 700;
      transition: all 0.3s ease;
      color: #94A3B8;
      position: relative;
      overflow: hidden;
    }

    .nav-item i {
      width: 20px;
      transition: all 0.3s ease;
    }

    .nav-item:hover {
      background: #F0F6FF;
      color: #5A9BD4;
      transform: translateX(4px);
    }

    .nav-item:hover i {
      transform: scale(1.1);
    }

    .nav-item.active {
      background: var(--accent);
      color: white !important;
      box-shadow: 0 8px 25px rgba(90, 155, 212, 0.35);
    }

    .nav-item.active i {
      color: white !important;
    }

    [data-theme="dark"] .nav-item:hover {
      background: #334155;
      color: #60A5FA;
    }

    .app-logo {
      width: 52px;
      height: 52px;
      background: linear-gradient(135deg, var(--accent), #7EB8E8);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      color: white;
      box-shadow: 0 6px 20px rgba(90, 155, 212, 0.35);
      position: relative;
      transition: transform 0.3s ease;
    }

    .app-logo:hover {
      transform: scale(1.05);
    }

   

    .card-shadow {
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
      border: 1px solid var(--card-border);
      background: white;
    }

    .banner-gradient {
      background: linear-gradient(135deg, var(--accent), #7EB8E8);
    }

    .mood-btn {
      transition: all 0.25s;
      border: 1px solid var(--card-border);
      background: white;
    }

    .mood-btn:hover {
      border-color: var(--accent);
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(163, 196, 232, 0.25);
    }

    .bear-float {
      animation: float 3.5s ease-in-out infinite;
    }

    @keyframes float {

      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-10px);
      }
    }

    .theme-switch {
      position: relative;
      display: inline-block;
      width: 44px;
      height: 24px;
    }

    .theme-switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: #cbd5e1;
      transition: 0.3s;
      border-radius: 34px;
    }

    .slider:before {
      position: absolute;
      content: "";
      height: 18px;
      width: 18px;
      left: 3px;
      bottom: 3px;
      background-color: white;
      transition: 0.3s;
      border-radius: 50%;
    }

    input:checked+.slider {
      background-color: var(--accent);
    }

    input:checked+.slider:before {
      transform: translateX(20px);
    }

    /* Active menu indicator */
    .nav-item.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 4px;
      height: 60%;
      background: white;
      border-radius: 0 4px 4px 0;
    }

    [data-theme="dark"] .nav-item.active::before {
      background: #60A5FA;
    }
  </style>
</head>

<body class="flex h-screen overflow-hidden">

  <aside class="w-[260px] bg-white border-r border-[#E0ECF9] flex flex-col p-6">
    <div class="flex items-center gap-3 mb-10">
      <div class="app-logo">🐻</div>
      <div>
        <h1 class="font-bold text-2xl leading-none text-[#2C4A7C]">Bear Diary</h1>
        <p class="text-[10px] text-[#5A9BD4] font-bold uppercase tracking-[1px]">YOUR DAILY JOURNAL</p>
      </div>
    </div>

    <nav class="flex-1 space-y-2">
      <a href="/" class="nav-item <%= title === 'Trang chủ - Moodiary' ? 'active' : '' %>">
        <i class="fa-solid fa-house"></i>
        <span>Trang chủ</span>
      </a>
      <a href="/diaries/timeline"
        class="nav-item <%= title === 'Dòng thời gian - Moodiary' || title === 'Nhật ký - Moodiary' ? 'active' : '' %>">
        <i class="fa-solid fa-book-open"></i>
        <span>Timeline</span>
      </a>
      <a href="/diaries/report"
        class="nav-item <%= title === 'Mood Report - Moodiary' || title === 'Báo cáo - Moodiary' ? 'active' : '' %>">
        <i class="fa-solid fa-chart-simple"></i>
        <span>Báo cáo</span>
      </a>
      <a href="/diaries/profile" class="nav-item <%= title === 'Cá nhân - Moodiary' ? 'active' : '' %>">
        <i class="fa-solid fa-user"></i>
        <span>Cá nhân</span>
      </a>
    </nav>

    <div class="mt-auto space-y-4">
      <div class="flex items-center justify-between px-4 py-3">
        <div class="flex items-center gap-4 font-bold text-slate-400">
          <i class="fa-solid fa-moon"></i> Chế độ tối
        </div>
        <label class="theme-switch">
          <input type="checkbox" id="darkToggle" onchange="handleDarkModeToggle()">
          <span class="slider"></span>
        </label>
      </div>
      <a href="/auth/logout" class="nav-item text-rose-400 hover:text-rose-600 hover:bg-rose-50">
        <i class="fa-solid fa-arrow-right-from-bracket"></i>
        <span>Đăng xuất</span>
      </a>
      <div class="flex justify-center pt-4">
        <div class="w-16 h-16 bg-[#E0ECF9] rounded-2xl flex items-center justify-center text-4xl bear-float">🐻</div>
      </div>
    </div>
  </aside>

  <main class="flex-1 overflow-y-auto p-8">
    <%- body %>
  </main>

  <script>
    // Hiển thị ngày tháng
    const dateOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
    const dateEl = document.getElementById('currentDate');
    if (dateEl) {
      dateEl.innerText = new Date().toLocaleDateString('vi-VN', dateOptions);
    }

    // Quản lý Theme & Dark Mode
    function setTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('moodiary-theme', theme);
    }

    function handleDarkModeToggle() {
      const toggle = document.getElementById('darkToggle');
      if (toggle.checked) {
        setTheme('dark');
      } else {
        const savedTheme = localStorage.getItem('moodiary-previous-theme') || 'blue';
        setTheme(savedTheme);
      }
    }

    window.onload = function () {
      const savedTheme = localStorage.getItem('moodiary-theme');
      if (savedTheme && savedTheme !== 'dark') {
        localStorage.setItem('moodiary-previous-theme', savedTheme);
      }
      const themeToLoad = savedTheme || 'blue';
      setTheme(themeToLoad);
      const toggle = document.getElementById('darkToggle');
      if (toggle) toggle.checked = (themeToLoad === 'dark');
    };
  </script>
</body>

</html>