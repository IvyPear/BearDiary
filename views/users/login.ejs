<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Moodiary - Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Nunito', sans-serif; }
    
    .left-panel {
      background: radial-gradient(circle at center, #E0F0FF 0%, #C9E4FF 100%);
    }

    .bear-shadow {
      filter: drop-shadow(0 20px 30px rgba(59, 130, 246, 0.15));
    }

    .feature-pill {
      background: white;
      padding: 6px 18px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
      color: #3B82F6;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.03);
    }

    .input-field {
      background: #F8FBFF;
      border: 1px solid #EBF4FF;
      border-radius: 12px;
      padding: 12px 16px;
      transition: all 0.3s;
    }

    .input-field:focus {
      border-color: #3B82F6;
      background: white;
      box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
      outline: none;
    }

    .btn-login {
      background: #3B82F6;
      box-shadow: 0 10px 20px rgba(59, 130, 246, 0.25);
      transition: all 0.3s;
    }

    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 25px rgba(59, 130, 246, 0.35);
      background: #2563EB;
    }

    .floating {
      animation: float 4s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-15px); }
    }
  </style>
</head>
<body class="h-screen flex overflow-hidden">

  <div class="hidden lg:flex w-[60%] left-panel flex-col items-center justify-center p-12 relative">
    <div class="absolute top-20 left-20 w-32 h-32 bg-white/30 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-20 w-48 h-48 bg-blue-400/10 rounded-full blur-3xl"></div>

    <div class="flex flex-col items-center text-center z-10">
      <div class="w-72 h-72 mb-8 floating">
        <div class="w-full h-full bg-white/40 rounded-full flex items-center justify-center bear-shadow" style="font-size: 160px;">
          🐻
        </div>
      </div>
      
      <h1 class="text-5xl font-black text-[#1E3A8A] mb-2">Moodiary</h1>
      <p class="text-[#3B82F6] font-bold text-lg mb-8">Your personal mood & diary companion ☀️</p>
      
      <div class="flex gap-3">
        <span class="feature-pill">Track moods</span>
        <span class="feature-pill">Write freely</span>
        <span class="feature-pill">See patterns</span>
      </div>
    </div>
  </div>

  <div class="w-full lg:w-[40%] bg-white flex flex-col items-center justify-center p-8 md:p-16">
    <div class="w-full max-w-md">
      
      <div class="mb-10">
        <div class="flex items-center gap-2 text-blue-500 font-bold text-sm uppercase tracking-widest mb-2">
          <i class="fa-solid fa-sparkles"></i> Welcome Back
        </div>
        <h2 class="text-3xl font-extrabold text-[#1E3A8A]">Sign in to your diary</h2>
        <p class="text-slate-400 font-medium mt-1">Good to see you again! ✨</p>
      </div>

      <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl mb-6 font-bold text-sm">
          <%= error_msg %>
        </div>
      <% } %>

      <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
        <div class="bg-emerald-100 border border-emerald-400 text-emerald-700 px-4 py-3 rounded-xl mb-6 font-bold text-sm">
          <%= success_msg %>
        </div>
      <% } %>

      <form action="/auth/login" method="POST" class="space-y-6">
        <div>
          <label class="block text-sm font-bold text-slate-500 mb-2">Email Address</label>
          <input type="email" name="email" placeholder="luna@example.com" 
                 class="w-full input-field font-medium text-slate-700" required>
        </div>

        <div class="relative">
          <label class="block text-sm font-bold text-slate-500 mb-2">Password</label>
          <div class="relative">
            <input type="password" name="password" placeholder="••••••••" 
                   class="w-full input-field font-medium text-slate-700" required>
            <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-300 hover:text-slate-500">
              <i class="fa-solid fa-eye"></i>
            </button>
          </div>
        </div>

        <div class="flex justify-end">
          <a href="#" class="text-sm font-bold text-blue-500 hover:underline">Forgot password?</a>
        </div>

        <button type="submit" class="w-full btn-login text-white py-4 rounded-2xl font-black text-lg mt-4">
          Sign In
        </button>
      </form>

      <div class="mt-8 text-center">
        <p class="text-slate-400 font-bold text-sm">
          Don't have an account? 
          <a href="/auth/register" class="text-blue-500 hover:underline">Register</a>
        </p>
      </div>

    </div>
  </div>

</body>
</html>